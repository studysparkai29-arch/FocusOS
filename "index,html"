          user:     DB.getUser(),
          areas:    DB.getAreas(),
          goals:    DB.getGoals(),
          tasks:    DB.getTasks(),
          sessions: DB.getSessions(),
          habits:   DB.getHabits(),
          ideas:    DB.getIdeas()
        }
      };
      const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = `focusos-backup-${dd}-${mm}-${yyyy}.json`;
      a.click();
      URL.revokeObjectURL(url);
      Utils.haptic([40, 20, 40]);
      UI.showToast('Backup export ho gaya! 📤', '✅');
    } catch(e) {
      console.warn('[SETTINGS] export:', e);
      UI.showToast('Export fail hua', '❌');
    }
  },

  importBackup(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const data = JSON.parse(e.target.result);
        if (!data.app || !data.data) {
          UI.showToast('Invalid backup file', '❌'); return;
        }
        if (!confirm('Existing data replace ho jayega. Continue?')) { input.value=''; return; }
        const d = data.data;
        if (d.user)     DB.saveUser(d.user);
        if (d.areas)    DB.saveData(KEYS.AREAS,    d.areas);
        if (d.goals)    DB.saveData(KEYS.GOALS,    d.goals);
        if (d.tasks)    DB.saveData(KEYS.TASKS,    d.tasks);
        if (d.sessions) DB.saveData(KEYS.SESSIONS, d.sessions);
        if (d.habits)   DB.saveData(KEYS.HABITS,   d.habits);
        if (d.ideas)    DB.saveData(KEYS.IDEAS,     d.ideas);
        // Apply theme
        if (d.user && d.user.theme) document.documentElement.setAttribute('data-theme', d.user.theme);
        input.value = '';
        this.close();
        refreshAll();
        Utils.haptic([40,20,40]);
        UI.showToast('Backup restore ho gaya! 📥', '✅');
      } catch(err) {
        console.warn('[SETTINGS] import:', err);
        UI.showToast('Import fail — invalid file', '❌');
        input.value = '';
      }
    };
    reader.readAsText(file);
  },

  confirmReset() {
    if (!confirm('Sab data permanently delete ho jayega. Ek baar delete karne ke baad wapas nahi ayega. SURE ho?')) return;
    if (!confirm('Bilkul pakka? Ye action undo nahi ho sakta.')) return;
    Object.values(KEYS).forEach(k => localStorage.removeItem(k));
    Utils.haptic([80,40,80,40,80]);
    location.reload();
  },

  togglePrivacyTip() {
    const tip = document.getElementById('privacy-tooltip');
    if (!tip) return;
    tip.classList.toggle('show');
    setTimeout(() => tip.classList.remove('show'), 4000);
  }
};

/* ============================================
   INSTALL PROMPT MODULE (P9)
============================================ */
const INSTALL = {
  _deferredPrompt: null,
  _dismissed: false,

  init() {
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      this._deferredPrompt = e;
      if (!this._dismissed) {
        setTimeout(() => this.show(), 3000);
      }
    });
  },

  show() {
    const el = document.getElementById('install-prompt');
    if (el) el.classList.add('show');
  },

  dismiss() {
    this._dismissed = true;
    const el = document.getElementById('install-prompt');
    if (el) el.classList.remove('show');
  },

  async install() {
    if (!this._deferredPrompt) return;
    this._deferredPrompt.prompt();
    const result = await this._deferredPrompt.userChoice;
    this._deferredPrompt = null;
    this.dismiss();
    if (result.outcome === 'accepted') {
      UI.showToast('App install ho gaya! 🎉', '📱');
    }
  }
};

/* ============================================
   SERVICE WORKER
============================================ */
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    try {
      const sw = `
const CACHE='focusos-v2';
const OFFLINE_HTML = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>FocusOS — Offline</title><style>body{font-family:sans-serif;background:#0A0A0F;color:#F0F0F5;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;margin:0;text-align:center;}h1{font-size:32px;margin-bottom:8px;}p{color:#7070A0;}</style></head><body><h1>📴 Offline</h1><p>Internet nahi hai. App cached data use kar raha hai.</p></body></html>';
self.addEventListener('install', e => {
  e.waitUntil(caches.open(CACHE).then(c => c.addAll([])).then(() => self.skipWaiting()));
});
self.addEventListener('activate', e => {
  e.waitUntil(
    caches.keys().then(keys => Promise.all(keys.filter(k => k!==CACHE).map(k => caches.delete(k))))
    .then(() => clients.claim())
  );
});
self.addEventListener('fetch', e => {
  if (e.request.method !== 'GET') return;
  e.respondWith(
    caches.match(e.request).then(cached => {
      if (cached) return cached;
      return fetch(e.request).then(resp => {
        if (resp && resp.status === 200 && resp.type === 'basic') {
          const clone = resp.clone();
          caches.open(CACHE).then(c => c.put(e.request, clone));
        }
        return resp;
      }).catch(() => {
        if (e.request.headers.get('accept')?.includes('text/html')) {
          return new Response(OFFLINE_HTML, {headers:{'Content-Type':'text/html'}});
        }
      });
    })
  );
});`;
      const blob = new Blob([sw], { type: 'application/javascript' });
      navigator.serviceWorker.register(URL.createObjectURL(blob)).catch(() => {});
    } catch {}
  });
}

/* ============================================
   KEYBOARD SUPPORT
============================================ */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (SETTINGS._open) { SETTINGS.close(); return; }
    UI.closeFab();
    UI.closeIdeaModal();
    TASKS.closeAddTask();
    TASKS.closeConfirm();
  }
  if (e.key === 'Enter' && document.getElementById('onboarding')?.classList.contains('active')) UI.obNext();
});

/* ============================================
   BOOT
============================================ */
document.addEventListener('DOMContentLoaded', () => {
  // Apply saved theme before render
  try {
    const user = DB.getUser();
    if (user && user.theme) {
      document.documentElement.setAttribute('data-theme', user.theme);
    }
  } catch {}
  // Init install prompt
  INSTALL.init();
  // Boot app
  UI.init();
});
</script>
