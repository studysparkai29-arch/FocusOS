    if (!area) return;
    if (!confirm(`"${area.name}" area delete karna chahte ho? Iske saare goals aur tasks bhi remove ho jayenge.`)) return;
    const filtered = areas.filter(a => a.id !== id);
    DB.saveData(KEYS.AREAS, filtered);
    // Also remove goals/tasks linked to this area
    const goals = DB.getGoals().filter(g => g.areaId !== id);
    DB.saveData(KEYS.GOALS, goals);
    const tasks = DB.getTasks().filter(t => t.areaId !== id);
    DB.saveData(KEYS.TASKS, tasks);
    const list = document.getElementById('s-areas-list');
    if (list) list.innerHTML = this._renderAreasList(DB.getAreas());
    refreshAll();
    Utils.haptic(30);
    UI.showToast('Area delete ho gaya', '🗑️');
