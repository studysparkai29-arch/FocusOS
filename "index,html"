============================================ */
const WEEKLY_REVIEW = {

  _selectedAreaId: null,

  /* ------------------------------------------
     TRIGGER CHECK (Sunday + not yet reviewed)
  ------------------------------------------ */
  check() {
    try {
      const user = DB.getUser();
      if (!user || !user.onboardingDone) return;
      const today = new Date();
      // 0 = Sunday
      if (today.getDay() !== 0) return;
      const weekStr      = Utils.getWeekString();
      const lastReview   = DB.getData(KEYS.LAST_REVIEW);
      if (lastReview === weekStr) return;
      this.open();
    } catch(e) { console.warn('[WEEKLY_REVIEW] check:', e); }
  },

  open() {
    this._selectedAreaId = null;
    this._populate();
    const overlay = document.getElementById('weekly-review-overlay');
    if (!overlay) return;
    overlay.style.display = 'flex';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => overlay.classList.add('active'));
    });
    Utils.haptic(60);
  },

  close() {
    const overlay = document.getElementById('weekly-review-overlay');
    if (!overlay) return;
    overlay.classList.remove('active');
    setTimeout(() => { overlay.style.display = 'none'; }, 300);
  },

  /* ------------------------------------------
     POPULATE ALL SECTIONS
  ------------------------------------------ */
  _populate() {
    this._setWeekRange();
    this._renderFocusSummary();
    this._renderAchievements();
    this._renderBestWorst();
    this._renderInsights();
    this._renderAreaGrid();
  },

  /* Week range label: "3–9 March 2026" */
  _setWeekRange() {
    const el = document.getElementById('wr-week-range');
    if (!el) return;
    const now = new Date();
    // Monday of current week
    const day = now.getDay() || 7;
    const mon = new Date(now); mon.setDate(now.getDate() - day + 1);
    const sun = new Date(mon); sun.setDate(mon.getDate() + 6);
    const opts = { day: 'numeric', month: 'long', year: 'numeric' };
    const monS = mon.toLocaleDateString('en-IN', opts);
    const sunS = sun.toLocaleDateString('en-IN', { day: 'numeric' });
    el.textContent = `${sunS}–${monS}`;
  },

  /* Section 1: Focus bars per area */
  _renderFocusSummary() {
    const el = document.getElementById('wr-focus-summary');
    if (!el) return;

    const areas     = DB.getAreas();
    const weekAgo   = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
    const sessions  = DB.getSessions().filter(s => s.completedAt > weekAgo);

    const vals = areas.map(a => {
      const mins = sessions.filter(s => s.areaId === a.id).reduce((sum, s) => sum + (s.duration || 0), 0);
      return { area: a, hrs: parseFloat((mins / 60).toFixed(1)) };
    }).sort((a, b) => b.hrs - a.hrs);

    const maxHrs = Math.max(...vals.map(v => v.hrs), 1);

    if (vals.length === 0 || vals.every(v => v.hrs === 0)) {
      el.innerHTML = `<div style="font-size:13px;color:var(--muted);text-align:center;padding:16px;">Is hafte koi focus session nahi tha</div>`;
      return;
    }

    el.innerHTML = vals.map(v => `
      <div class="wr-area-bar-row">
        <div class="wr-area-bar-label">${v.area.icon} ${UI.escapeHtml(v.area.name)}</div>
        <div class="wr-area-bar-track">
          <div class="wr-area-bar-fill" style="width:${(v.hrs/maxHrs)*100}%;background:${v.area.color};"></div>
        </div>
        <div class="wr-area-bar-val">${v.hrs}h</div>
      </div>`).join('');
  },

  /* Section 2: Achievement stats */
  _renderAchievements() {
    const el = document.getElementById('wr-achievements');
    if (!el) return;

    const weekAgo   = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
    const tasks     = DB.getTasks();
    const mitTasks  = tasks.filter(t => t.isMIT);
    const mitDone   = mitTasks.filter(t => t.completed && t.completedAt > weekAgo).length;
    const tasksDone = tasks.filter(t => t.completed && t.completedAt > weekAgo).length;
    const totalTasks = tasks.length;

    const habits    = DB.getHabits();
    const weekDays  = 7;
    const habitTotal  = habits.length * weekDays;
    const habitsDone  = habits.reduce((sum, h) => {
      const weekAgoDate = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
      return sum + (h.completedDates || []).filter(d => d >= weekAgoDate).length;
    }, 0);

    const sessions = DB.getSessions().filter(s => s.completedAt > weekAgo);

    const taskPct  = totalTasks > 0    ? Math.round((tasksDone / totalTasks) * 100) : 0;
    const mitPct   = mitTasks.length > 0 ? Math.round((mitDone / mitTasks.length) * 100) : 0;
    const habitPct = habitTotal > 0    ? Math.round((habitsDone / habitTotal) * 100) : 0;

    const rows = [
      { icon: '✅', label: 'Tasks completed',  val: `${tasksDone}/${totalTasks}`,             pct: taskPct,  color: taskPct  >= 70 ? 'var(--success)' : 'var(--text)' },
      { icon: '🎯', label: 'MIT done',         val: `${mitDone}/${mitTasks.length}`,          pct: mitPct,   color: mitPct   >= 70 ? 'var(--primary)' : 'var(--text)' },
      { icon: '🔁', label: 'Habits kept',      val: `${habitsDone}/${habitTotal}`,            pct: habitPct, color: habitPct >= 70 ? 'var(--success)' : 'var(--text)' },
      { icon: '🍅', label: 'Total sessions',   val: `${sessions.length}`,                     pct: null,     color: 'var(--text)' },
    ];

    el.innerHTML = rows.map(r => `
      <div class="wr-achieve-row">
        <div class="wr-achieve-icon">${r.icon}</div>
        <div class="wr-achieve-label">${r.label}</div>
        <div class="wr-achieve-val">${r.val}</div>
        ${r.pct !== null ? `<div class="wr-achieve-pct" style="color:${r.color};">${r.pct}%</div>` : ''}
      </div>`).join('');
  },

  /* Section 3: Best/Worst day */
  _renderBestWorst() {
    const el = document.getElementById('wr-bestworst');
    if (!el) return;

    const dayNames  = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const sessions  = DB.getSessions();
    const today     = new Date();

    const days = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today); d.setDate(today.getDate() - i);
      const dateStr = d.toISOString().split('T')[0];
      const mins = sessions.filter(s => s.completedAt?.startsWith(dateStr))
                           .reduce((sum, s) => sum + (s.duration || 0), 0);
      days.push({ name: dayNames[d.getDay()], hrs: parseFloat((mins / 60).toFixed(1)) });
    }

    const sorted = [...days].sort((a, b) => b.hrs - a.hrs);
    const best  = sorted[0];
    const worst = sorted[sorted.length - 1];

    el.innerHTML = `
      <div class="wr-bestworst-row best">
        <div>
          <div class="wr-bw-label">Best Day</div>
          <div class="wr-bw-val">🏆 ${best.name} — ${best.hrs}h</div>
        </div>
      </div>
      <div class="wr-bestworst-row worst">
        <div>
          <div class="wr-bw-label">Needs Improvement</div>
          <div class="wr-bw-val">⚠️ ${worst.name} — ${worst.hrs}h</div>
        </div>
      </div>`;
  },

  /* Section 4: Smart Insights */
  _renderInsights() {
    const el = document.getElementById('wr-insights');
    if (!el) return;

    const weekAgo    = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
    const sessions   = DB.getSessions().filter(s => s.completedAt > weekAgo);
    const areas      = DB.getAreas();

    const areaData = areas.map(a => ({
      area: a,
      mins: sessions.filter(s => s.areaId === a.id).reduce((sum, s) => sum + (s.duration || 0), 0)
    }));
    const avgMins = areaData.length > 0
      ? areaData.reduce((s, a) => s + a.mins, 0) / areaData.length
      : 0;

    const tasks    = DB.getTasks();
    const mitTasks = tasks.filter(t => t.isMIT);
    const mitDone  = mitTasks.filter(t => t.completed && t.completedAt > weekAgo).length;
    const mitPct   = mitTasks.length > 0 ? Math.round((mitDone / mitTasks.length) * 100) : 0;

    const habits   = DB.getHabits();
    const habitTotal = habits.length * 7;
    const habitsDone = habits.reduce((sum, h) => {
      const weekAgoDate = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
      return sum + (h.completedDates || []).filter(d => d >= weekAgoDate).length;
    }, 0);
    const habitPct = habitTotal > 0 ? Math.round((habitsDone / habitTotal) * 100) : 0;

    const insights = [];

    // Weak areas (below average sessions)
    const weakAreas = areaData.filter(a => a.mins < avgMins * 0.6 && a.area);
    weakAreas.slice(0, 2).forEach(a => {
      insights.push({ icon: a.area.icon, text: `${a.area.name} thoda low raha. Agla hafte: +2 sessions try karo!` });
    });

    // MIT praise
    if (mitPct >= 80) insights.push({ icon: '🎯', text: 'MIT game strong hai! ' + mitPct + '% tasks complete. Jaari rakho!' });

    // Habits praise
    if (habitPct >= 75) insights.push({ icon: '💪', text: 'Habits consistent rahi! ' + habitPct + '% completion — great work!' });

    // Low overall focus
    if (sessions.length < 5) insights.push({ icon: '⏱️', text: 'Sirf ' + sessions.length + ' sessions is hafte. Agla hafte aur sessions target karo!' });

    // Good week overall
    if (sessions.length >= 10 && mitPct >= 70) insights.push({ icon: '⭐', text: 'Yeh ek solid week thi! Consistency power hai.' });

    if (insights.length === 0) insights.push({ icon: '📊', text: 'Data accumulate ho raha hai. Thoda aur focus karo!' });

    el.innerHTML = insights.map(ins => `
      <div class="wr-insight-item">
        <div class="wr-insight-icon">${ins.icon}</div>
        <div class="wr-insight-text">${ins.text}</div>
      </div>`).join('');
  },

  /* Section 5: Area select grid */
  _renderAreaGrid() {
    const grid = document.getElementById('wr-area-grid');
    if (!grid) return;
    const areas = DB.getAreas();
    if (areas.length === 0) {
      grid.innerHTML = `<div style="grid-column:1/-1;font-size:13px;color:var(--muted);text-align:center;padding:16px;">Koi areas nahi</div>`;
      return;
    }
    grid.innerHTML = areas.map(a => `
      <div class="wr-area-btn" id="wr-ab-${a.id}" onclick="WEEKLY_REVIEW.selectArea('${a.id}')"
           style="border-color:${this._selectedAreaId === a.id ? a.color : 'var(--border)'};
                  background:${this._selectedAreaId === a.id ? a.color + '22' : 'var(--card)'};">
        <div style="font-size:26px;">${a.icon}</div>
        <div style="font-size:13px;font-weight:700;color:var(--text);">${UI.escapeHtml(a.name)}</div>
      </div>`).join('');
  },

  selectArea(id) {
    this._selectedAreaId = id;
    this._renderAreaGrid();
    Utils.haptic(25);
  },

  /* ------------------------------------------
     COMPLETE REVIEW
  ------------------------------------------ */
  complete() {
    try {
      const weekStr = Utils.getWeekString();
      DB.saveData(KEYS.LAST_REVIEW, weekStr);

      // Save next week main area if selected
      if (this._selectedAreaId) {
        const user = DB.getUser();
        if (user) { user.todayMainArea = this._selectedAreaId; DB.saveUser(user); }
      }

      // Award coins
      UI.addCoins(10, null);
      UI.showCoinPop('+10\uD83E\uDE99');
      Utils.haptic([80, 40, 80]);

      // Confetti
      try {
        if (typeof confetti !== 'undefined') {
          confetti({ particleCount: 80, spread: 70, origin: { y: 0.5 }, colors: ['#6C63FF','#F0C040','#40D080','#FF6B9D'] });
        }
      } catch {}

      this.close();
      setTimeout(() => UI.showToast('Review done! +10 coins \uD83C\uDF89', '\uD83C\uDFC6'), 400);
      refreshAll();
    } catch(e) { console.warn('[WEEKLY_REVIEW] complete:', e); }
  }
};

