    });

    this.closeAddGoal();
    Utils.haptic(70);
    UI.showToast('Goal add ho gaya! 🎯', '✅');
    refreshGoals();
  }
};

/* ============================================
   P6 — HABITS MODULE
============================================ */
const HABITS = {

  /* Form state */
  _ahForm: { areaId: null, freq: 'daily' },

  /* ============================================
     RENDER
  ============================================ */
  render() {
    try {
      this._renderTodayProgress();
      this._renderHabitsList();
    } catch(e) { console.warn('[HABITS] render:', e); }
  },

  /* Today's progress bar */
  _renderTodayProgress() {
    const habits = DB.getHabits();
    const today  = Utils.today();
    const dailyHabits = habits.filter(h => h.frequency === 'daily' || !h.frequency);
    const total  = dailyHabits.length;
    const done   = dailyHabits.filter(h => h.completedDates && h.completedDates.includes(today)).length;
    const pct    = total > 0 ? Math.round((done / total) * 100) : 0;

    const pctEl  = document.getElementById('habits-today-pct');
    const fillEl = document.getElementById('habits-today-fill');
    const subEl  = document.getElementById('habits-today-sub');
    if (pctEl)  pctEl.textContent  = `${pct}%`;
    if (fillEl) fillEl.style.width = `${pct}%`;
    if (subEl)  subEl.textContent  = `${done} / ${total} habits done aaj`;
  },

  /* Habits list grouped by area */
  _renderHabitsList() {
    const list  = document.getElementById('habits-list');
    const empty = document.getElementById('habits-empty');
    if (!list) return;

    const habits = DB.getHabits();
    if (habits.length === 0) {
      empty?.classList.remove('hidden');
      list.innerHTML = '';
      return;
    }
    empty?.classList.add('hidden');

    const areas  = DB.getAreas();
    const today  = Utils.today();

    // Group by areaId
    const groups = {};
    const noArea = [];
    habits.forEach(h => {
      if (!h.areaId) { noArea.push(h); return; }
      if (!groups[h.areaId]) groups[h.areaId] = [];
      groups[h.areaId].push(h);
    });

    let html = '';

    // Render area groups
    areas.forEach(area => {
      const areaHabits = groups[area.id];
      if (!areaHabits || areaHabits.length === 0) return;
      const doneCnt = areaHabits.filter(h => h.completedDates?.includes(today)).length;
      html += `
        <div class="habit-area-group">
          <div class="habit-area-header">
            <span class="habit-area-icon">${area.icon}</span>
            <span class="habit-area-name" style="color:${area.color};">${UI.escapeHtml(area.name)}</span>
            <span class="habit-area-done-count">${doneCnt}/${areaHabits.length}</span>
          </div>
          ${areaHabits.map(h => this._habitCardHTML(h, area, today)).join('')}
        </div>`;
    });

    // No-area habits
    if (noArea.length > 0) {
      const doneCnt = noArea.filter(h => h.completedDates?.includes(today)).length;
      html += `
        <div class="habit-area-group">
          <div class="habit-area-header">
            <span class="habit-area-icon">🔁</span>
            <span class="habit-area-name">General</span>
            <span class="habit-area-done-count">${doneCnt}/${noArea.length}</span>
          </div>
          ${noArea.map(h => this._habitCardHTML(h, null, today)).join('')}
        </div>`;
    }

    list.innerHTML = html;
  },

  /* Individual habit card HTML */
  _habitCardHTML(habit, area, today) {
    const color   = area?.color || '#6C63FF';
    const isDone  = habit.completedDates?.includes(today);
    const streak  = habit.streak || 0;
    const missed  = this._daysMissed(habit);
    const isRecovery = missed > 2 && streak === 0;
    const freqLabel = habit.frequency === 'weekly' ? 'Weekly' : 'Daily';

    let extraCls = '';
    if (isDone)    extraCls = 'done-today';
    else if (missed > 0 && streak === 0) extraCls = 'missed';

    return `
      <div class="habit-card ${extraCls}" id="hcard-${habit.id}">
        <div class="habit-color-strip" style="background:${color};"></div>
        <div class="habit-cb" id="hcb-${habit.id}" onclick="HABITS.toggleHabit('${habit.id}')" title="${isDone ? 'Done!' : 'Mark as done'}">${isDone ? '✓' : ''}</div>
        <div class="habit-content">
          <div class="habit-title">${UI.escapeHtml(habit.title)}</div>
          <div class="habit-meta">
            <div class="habit-streak ${streak === 0 ? 'cold' : ''}">
              ${streak > 0 ? `🔥${streak}` : '🌱0'}
            </div>
            <div class="habit-freq">${freqLabel}</div>
            ${isRecovery ? `<div class="habit-recovery">Kal se wapas shuru karo 🙏</div>` : ''}
            ${isDone ? `<div style="font-size:11px;color:var(--success);font-weight:600;">✓ Done aaj</div>` : ''}
          </div>
        </div>
        ${streak >= 7 ? `<div style="font-size:18px;margin-right:4px;" title="${streak} din streak!">🏅</div>` : ''}
      </div>`;
  },

  /* Days since last completion */
  _daysMissed(habit) {
    if (!habit.completedDates || habit.completedDates.length === 0) return 999;
    const dates = habit.completedDates.slice().sort();
    const last  = dates[dates.length - 1];
    const today = Utils.today();
    if (last === today) return 0;
    const diff  = Math.floor((new Date(today) - new Date(last)) / 86400000);
    return diff;
  },

  /* ============================================
     TOGGLE / COMPLETE HABIT
  ============================================ */
  toggleHabit(id) {
    try {
      const habits = DB.getHabits();
      const habit  = habits.find(h => h.id === id);
      if (!habit) return;
      const today = Utils.today();
      const dates = habit.completedDates ? [...habit.completedDates] : [];
      const idx   = dates.indexOf(today);

      if (idx !== -1) {
        // Uncheck — remove today
        dates.splice(idx, 1);
        habit.completedDates = dates;
        habit.streak = this._calcStreak(dates);
        DB.saveHabits(habits);
        Utils.haptic(20);
      } else {
        // Complete — add today
        dates.push(today);
        habit.completedDates = dates;
        const newStreak = this._calcStreak(dates);
        const prevStreak = habit.streak || 0;
        habit.streak = newStreak;
        DB.saveHabits(habits);

        // Award coin
        UI.addCoins(1, null);
        UI.showCoinPop('+1🪙');
        Utils.haptic(70);

        // Streak message
        UI.showToast(`🔥 Streak: ${newStreak} din! Habit complete!`, '✅');

        // Milestone checks
        this._checkMilestone(newStreak, prevStreak, habit.title);
      }

      // Animate card
      const card = document.getElementById(`hcard-${id}`);
      if (card) {
        card.style.transform = 'scale(0.97)';
        setTimeout(() => { card.style.transform = ''; }, 150);
      }

      this.render();
      refreshHome();
      refreshStats();
    } catch(e) { console.warn('[HABITS] toggleHabit:', e); }
  },

  /* Calculate streak from completedDates array */
  _calcStreak(dates) {
    if (!dates || dates.length === 0) return 0;
    const sorted = dates.slice().sort().reverse(); // newest first
    const today  = Utils.today();
    let streak   = 0;
    let check    = today;

    for (const d of sorted) {
      if (d === check) {
        streak++;
        // Previous day
        const prev = new Date(check);
        prev.setDate(prev.getDate() - 1);
        check = prev.toISOString().split('T')[0];
      } else if (d < check) {
        break; // gap found
      }
    }
    return streak;
  },

  /* ============================================
     MILESTONE CELEBRATIONS
  ============================================ */
  _checkMilestone(newStreak, prevStreak, title) {
    // Only fire if we just crossed the threshold
    const milestones = [7, 21, 30];
    for (const m of milestones) {
      if (newStreak === m && prevStreak < m) {
        this._fireMilestone(m, title);
        return;
      }
    }
  },

  _fireMilestone(days, title) {
    let emoji, msg, coins = 0, confettiLevel = 0;
    if (days === 7)  { emoji = '🔥'; msg = 'Week Warrior!';    confettiLevel = 1; }
    if (days === 21) { emoji = '💪'; msg = 'Habit Locked!';    confettiLevel = 2; }
    if (days === 30) { emoji = '🏆'; msg = 'Consistent 💪';   confettiLevel = 3; coins = 20; }

    // Confetti
    try {
      if (typeof confetti !== 'undefined') {
        if (confettiLevel >= 1) confetti({ particleCount: 60 + confettiLevel * 30, spread: 70, origin: { y: 0.5 }, colors: ['#F0C040','#6C63FF','#40D080','#FF6B9D'] });
        if (confettiLevel >= 2) setTimeout(() => confetti({ particleCount: 50, spread: 50, origin: { y: 0.3 } }), 500);
        if (confettiLevel >= 3) setTimeout(() => confetti({ particleCount: 80, spread: 100, origin: { y: 0.6 } }), 900);
      }
    } catch {}

    // Flash the card
    if (days === 30 && coins > 0) UI.addCoins(coins, null);

    // Badge
    GOALS._unlockBadge(emoji, `${msg} — ${days} din! 🎉`, `"${title}" — ${days} din ka streak!`);

    Utils.haptic(days >= 21 ? [100,50,100,50,100] : [80,40,80]);
  },

  /* ============================================
     ADD HABIT SHEET
  ============================================ */
  showAddHabit() {
    this._ahForm = { areaId: null, freq: 'daily' };

    const titleEl = document.getElementById('ah-title');
    if (titleEl) titleEl.value = '';

    this._renderAhAreaPills();
    this._resetFreqChips();

    const overlay = document.getElementById('add-habit-overlay');
    if (overlay) overlay.classList.add('open');
    setTimeout(() => document.getElementById('ah-title')?.focus(), 350);
    Utils.haptic(30);

    // Ensure we're on habits subtab
    if (GOALS.activeSubtab !== 'habits') GOALS.switchSubtab('habits');
  },

  closeAddHabit() {
    document.getElementById('add-habit-overlay')?.classList.remove('open');
  },

  handleSheetOverlayClick(e) {
    if (e.target === document.getElementById('add-habit-overlay')) this.closeAddHabit();
  },

  _renderAhAreaPills() {
    const container = document.getElementById('ah-area-pills');
    if (!container) return;
    const areas = DB.getAreas();
    if (areas.length === 0) { container.innerHTML = '<span style="font-size:13px;color:var(--muted);">Koi areas nahi</span>'; return; }
    container.innerHTML = [
      `<div class="area-pill-btn ${this._ahForm.areaId === null ? 'active' : ''}" onclick="HABITS.selectAhArea(null)" style="${this._ahForm.areaId === null ? 'border-color:var(--primary);background:var(--primary-soft);color:var(--primary);' : ''}">Koi nahi</div>`,
      ...areas.map(a => `<div class="area-pill-btn ${this._ahForm.areaId === a.id ? 'active' : ''}" onclick="HABITS.selectAhArea('${a.id}')" style="${this._ahForm.areaId === a.id ? `border-color:${a.color};background:${a.color}22;color:${a.color};` : ''}">${a.icon} ${UI.escapeHtml(a.name)}</div>`)
    ].join('');
  },

  selectAhArea(id) {
    this._ahForm.areaId = id;
    this._renderAhAreaPills();
    Utils.haptic(20);
  },

  selectFreq(val) {
    this._ahForm.freq = val;
    this._resetFreqChips(val);
    Utils.haptic(20);
  },

  _resetFreqChips(active) {
    const val = active || this._ahForm.freq || 'daily';
    document.querySelectorAll('#ah-freq-group .chip-toggle').forEach(c => {
      const isActive = c.dataset.val === val;
      c.className = 'chip-toggle' + (isActive ? ' active energy-medium-active' : '');
    });
  },

  saveHabit() {
    const title = document.getElementById('ah-title')?.value?.trim();
    if (!title) {
      UI.showToast('Title dalna zaroori hai! 🔁', '⚠️');
      document.getElementById('ah-title')?.focus();
      return;
    }
    DB.addHabit({
      title,
      areaId:    this._ahForm.areaId,
      frequency: this._ahForm.freq || 'daily'
    });
    this.closeAddHabit();
    Utils.haptic(70);
    UI.showToast('Habit add ho gaya! 🔁', '✅');
    this.render();
    refreshHome();
  }
};

