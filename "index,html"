DB.updateGoal = function(id, changes) {
  const goals = this.getGoals();
  const idx   = goals.findIndex(g => g.id === id);
  if (idx === -1) return null;
  goals[idx] = { ...goals[idx], ...changes };
  this.saveGoals(goals);
  return goals[idx];
};

