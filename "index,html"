    if (areas.length === 0) { container.innerHTML = '<span style="font-size:13px;color:var(--muted);">Koi areas nahi</span>'; return; }
    container.innerHTML = [
      `<div class="area-pill-btn ${this._agForm.areaId === null ? 'active' : ''}" onclick="GOALS.selectAgArea(null)" style="${this._agForm.areaId === null ? 'border-color:var(--primary);background:var(--primary-soft);color:var(--primary);' : ''}">Koi nahi</div>`,
      ...areas.map(a => `<div class="area-pill-btn ${this._agForm.areaId === a.id ? 'active' : ''}" onclick="GOALS.selectAgArea('${a.id}')" style="${this._agForm.areaId === a.id ? `border-color:${a.color};background:${a.color}22;color:${a.color};` : ''}">${a.icon} ${UI.escapeHtml(a.name)}</div>`)
    ].join('');
  },

