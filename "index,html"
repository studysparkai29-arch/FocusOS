  showIdeaModal() { document.getElementById('idea-modal')?.classList.add('open'); setTimeout(() => document.getElementById('idea-text')?.focus(), 300); },
  closeIdeaModal(event) {
    if (event && event.target !== document.getElementById('idea-modal')) return;
    document.getElementById('idea-modal')?.classList.remove('open');
    const t = document.getElementById('idea-text'); if (t) t.value = '';
  },
  saveIdea() {
    const text = document.getElementById('idea-text')?.value?.trim();
    if (!text) { this.showToast('Kuch likho toh sahi! 😄', '💡'); return; }
    DB.addIdea({ title: text }); this.closeIdeaModal();
    this.showToast('Idea save ho gaya! 💡', '✨'); Utils.haptic(60);
  },

  /* ---- Toast ---- */
  showToast(message, icon) {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerHTML = `<span class="toast-icon">${icon || 'ℹ️'}</span><span>${message}</span>`;
    container.appendChild(toast);
    setTimeout(() => { toast.classList.add('removing'); setTimeout(() => toast.remove(), 300); }, 3000);
  },

  /* ---- Scroll headers ---- */
  setupScrollHeaders() {
    document.querySelectorAll('.screen').forEach(screen => {
      const header = screen.querySelector('.screen-header');
      if (!header) return;
      screen.addEventListener('scroll', () => header.classList.toggle('scrolled', screen.scrollTop > 10));
    });
  },

  /* ---- HTML escape ---- */
  escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
};

/* ============================================
   P3 — TASKS MODULE
============================================ */
const TASKS = {
  /* State */
  activeFilter: 'all',       // 'all' | 'mit' | areaId
  completedOpen: false,
  _pendingDelete: null,      // { type:'task'|'idea', id }
  _editId: null,             // null = new task

  /* Form state */
  _form: {
    priority: 'medium',
    energy: 'medium',
    isMIT: false,
    areaId: null,
  },

  /* ============================================
     RENDER PIPELINE
  ============================================ */
  render() {
    try {
      this.renderFilterBar();
      this.renderHeader();
      const tasks  = DB.getTasks();
      const ideas  = DB.getIdeas();

      // Filter tasks
      const filtered = this._filterTasks(tasks);
      const pending  = filtered.filter(t => !t.completed);
      const done     = filtered.filter(t => t.completed);
      const mits     = pending.filter(t => t.isMIT);
      const baaki    = pending.filter(t => !t.isMIT);

      // Show/hide full empty
      const fullEmpty = document.getElementById('tasks-full-empty');
      if (fullEmpty) fullEmpty.classList.toggle('hidden', tasks.length > 0 || ideas.length > 0);

      // MIT section
      this._renderMITSection(mits);

      // Baaki section
      this._renderBaakiSection(baaki);

      // Completed section
      this._renderCompletedSection(done);

      // Inbox
      this._renderInbox(ideas);

    } catch (e) { console.warn('[TASKS] render error:', e); }
  },

  renderHeader() {
    const tasks = DB.getTasks();
    const done  = tasks.filter(t => t.completed).length;
    const sub   = document.getElementById('tasks-subtitle');
    if (sub) sub.textContent = tasks.length > 0 ? `${done}/${tasks.length} done today` : 'Koi tasks nahi';
  },

  /* ============================================
     FILTER BAR
  ============================================ */
  renderFilterBar() {
    const bar = document.getElementById('tasks-filter-bar');
    if (!bar) return;
    const areas = DB.getAreas();

    const pills = [
      { id: 'all', label: 'Sab', icon: '' },
      { id: 'mit', label: 'MIT ⭐', icon: '', isMIT: true },
      ...areas.map(a => ({ id: a.id, label: `${a.icon} ${a.name}`, color: a.color }))
    ];

    bar.innerHTML = pills.map(p => {
      const isActive = this.activeFilter === p.id;
      const mitClass = p.isMIT ? 'mit-pill' : '';
      const activeStyle = isActive && p.color
        ? `style="border-color:${p.color};background:${p.color}22;color:${p.color};"`
        : '';
      return `<div class="filter-pill ${mitClass} ${isActive ? 'active' : ''}" ${activeStyle} onclick="TASKS.setFilter('${p.id}')">${p.label}</div>`;
    }).join('');
  },

  setFilter(id) {
    this.activeFilter = id;
    Utils.haptic(20);
    this.render();
  },

  _filterTasks(tasks) {
    if (this.activeFilter === 'all') return tasks;
    if (this.activeFilter === 'mit') return tasks.filter(t => t.isMIT);
    return tasks.filter(t => t.areaId === this.activeFilter);
  },

  /* ============================================
     SECTION RENDERS
  ============================================ */
  _renderMITSection(mits) {
    const section = document.getElementById('tasks-mit-section');
    const list    = document.getElementById('tasks-mit-list');
    const count   = document.getElementById('tasks-mit-count');
    if (!section || !list) return;

    if (mits.length === 0) { section.classList.add('hidden'); return; }
    section.classList.remove('hidden');
    if (count) count.textContent = mits.length;
    list.innerHTML = mits.map(t => this._taskCardHTML(t, true)).join('');
    this._attachSwipeListeners(list);
  },

  _renderBaakiSection(baaki) {
    const section = document.getElementById('tasks-baaki-section');
    const list    = document.getElementById('tasks-baaki-list');
    const count   = document.getElementById('tasks-baaki-count');
    if (!section || !list) return;

    // Sort: high → medium → low
    const sorted = [...baaki].sort((a, b) => {
      const order = { high: 0, medium: 1, low: 2 };
      return (order[a.priority] || 1) - (order[b.priority] || 1);
    });

    if (sorted.length === 0) { section.classList.add('hidden'); return; }
    section.classList.remove('hidden');
    if (count) count.textContent = sorted.length;
    list.innerHTML = sorted.map(t => this._taskCardHTML(t, false)).join('');
    this._attachSwipeListeners(list);
  },

  _renderCompletedSection(done) {
    const section = document.getElementById('tasks-done-section');
    const list    = document.getElementById('tasks-done-list');
    const count   = document.getElementById('tasks-done-count');
    const colBtn  = document.getElementById('tasks-collapse-btn');
    if (!section || !list) return;

    if (done.length === 0) { section.classList.add('hidden'); return; }
    section.classList.remove('hidden');
    if (count) count.textContent = done.length;

    list.innerHTML = done.map(t => this._taskCardHTML(t, false)).join('');
    list.style.maxHeight = this.completedOpen ? `${done.length * 80 + 20}px` : '0';
    if (colBtn) colBtn.classList.toggle('open', this.completedOpen);
  },

  toggleCompleted() {
    this.completedOpen = !this.completedOpen;
    const list   = document.getElementById('tasks-done-list');
    const colBtn = document.getElementById('tasks-collapse-btn');
    const done   = DB.getTasks().filter(t => t.completed).length;
    if (list) list.style.maxHeight = this.completedOpen ? `${done * 80 + 20}px` : '0';
    if (colBtn) colBtn.classList.toggle('open', this.completedOpen);
    Utils.haptic(20);
  },

  _renderInbox(ideas) {
    const section = document.getElementById('tasks-inbox-section');
    const list    = document.getElementById('tasks-inbox-list');
    const count   = document.getElementById('tasks-inbox-count');
    if (!list) return;
    if (count) count.textContent = ideas.length;

    if (ideas.length === 0) {
      list.innerHTML = `<div style="font-size:13px;color:var(--muted);text-align:center;padding:16px 0;">Koi ideas nahi — FAB se capture karo! 💡</div>`;
      return;
    }
    list.innerHTML = ideas.map(idea => `
      <div class="inbox-item" id="inbox-${UI.escapeHtml(idea.id)}">
        <div class="inbox-item-title">${UI.escapeHtml(idea.title)}</div>
        <div class="inbox-actions">
          <button class="inbox-btn task" onclick="TASKS.convertIdeaToTask('${idea.id}')">✅ Task banao</button>
          <button class="inbox-btn goal" onclick="TASKS.convertIdeaToGoal('${idea.id}')">🎯 Goal banao</button>
          <button class="inbox-btn del"  onclick="TASKS.promptDeleteIdea('${idea.id}')">🗑️</button>
        </div>
      </div>`).join('');
  },

  /* ============================================
     TASK CARD HTML
  ============================================ */
  _taskCardHTML(task, isMIT) {
    const areas = DB.getAreas();
    const area  = areas.find(a => a.id === task.areaId);
    const energyMap = { low: { icon: '🔋', label: 'Low',    cls: 'low'    },
                        medium: { icon: '⚡', label: 'Med',  cls: 'medium' },
                        deep:   { icon: '🧠', label: 'Deep', cls: 'deep'   } };
    const en = energyMap[task.energy || 'medium'];
    const priorityDot = `<div class="priority-dot ${task.priority || 'medium'}"></div>`;
    const dueTxt = this._dueDateText(task.dueDate);

    return `
      <div class="task-card-wrap" id="wrap-${task.id}">
        <div class="swipe-bg right"><span class="swipe-bg-text">✅ Complete</span></div>
        <div class="swipe-bg left"><span class="swipe-bg-text">🗑️ Delete</span></div>
        <div class="task-card ${isMIT ? 'mit-card' : ''} ${task.completed ? 'done' : ''}" id="card-${task.id}">
          <div class="task-cb" id="cb-${task.id}" onclick="event.stopPropagation();TASKS.completeTask('${task.id}')">${task.completed ? '✓' : ''}</div>
          <div class="task-body">
            <div class="task-title">${UI.escapeHtml(task.title)}</div>
            <div class="task-meta">
              ${priorityDot}
              <div class="energy-badge ${en.cls}">${en.icon} ${en.label}</div>
              ${area ? `<div class="area-tag" style="background:${area.color}22;color:${area.color};">${area.icon} ${UI.escapeHtml(area.name)}</div>` : ''}
              ${dueTxt}
            </div>
            ${task.energy === 'deep' && !task.completed && this._isNightTime() ? `<div class="energy-warning">🌙 Kal karo – raat mein deep work avoid karo</div>` : ''}
          </div>
          ${isMIT ? '<span class="mit-star">⭐</span>' : ''}
        </div>
      </div>`;
  },

  _isNightTime() { return new Date().getHours() >= 21; },

  _dueDateText(dateStr) {
    if (!dateStr) return '';
    const today    = Utils.today();
    const tomorrow = (() => { const d = new Date(); d.setDate(d.getDate()+1); return d.toISOString().split('T')[0]; })();
    let label, cls = '';
    if (dateStr < today)     { label = 'Overdue!'; cls = 'overdue'; }
    else if (dateStr === today)    { label = 'Aaj'; cls = 'overdue'; }
    else if (dateStr === tomorrow) { label = 'Kal'; }
    else { label = new Date(dateStr).toLocaleDateString('en-IN', { day:'numeric', month:'short' }); }
    return `<div class="due-tag ${cls}">📅 ${label}</div>`;
  },

  /* ============================================
     SWIPE GESTURES
  ============================================ */
  _attachSwipeListeners(container) {
    container.querySelectorAll('.task-card').forEach(card => {
      const taskId = card.id.replace('card-', '');
      if (card.dataset.swipeInit) return;
      card.dataset.swipeInit = '1';

      let startX = 0, currentX = 0, isDragging = false;
      const THRESHOLD = 72;

      const onStart = (e) => {
        if (e.target.closest('.task-cb')) return; // don't swipe on checkbox
        startX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
        currentX = startX;
        isDragging = true;
      };

      const onMove = (e) => {
        if (!isDragging) return;
        currentX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
        const dx = currentX - startX;
        if (Math.abs(dx) < 6) return;
        e.preventDefault();
        card.style.transform = `translateX(${dx * 0.6}px)`;

        const wrap = document.getElementById(`wrap-${taskId}`);
        if (wrap) {
          const bgL = wrap.querySelector('.swipe-bg.left');
          const bgR = wrap.querySelector('.swipe-bg.right');
          if (bgL) bgL.style.opacity = dx < 0 ? Math.min(Math.abs(dx) / THRESHOLD, 1) : 0;
          if (bgR) bgR.style.opacity = dx > 0 ? Math.min(dx / THRESHOLD, 1) : 0;
        }
      };

      const onEnd = () => {
        if (!isDragging) return;
        isDragging = false;
        const dx = currentX - startX;
        card.style.transform = '';

        const wrap = document.getElementById(`wrap-${taskId}`);
        if (wrap) {
          wrap.querySelectorAll('.swipe-bg').forEach(b => b.style.opacity = 0);
        }

        if (dx > THRESHOLD)       { this.completeTask(taskId); }
        else if (dx < -THRESHOLD) { this.promptDeleteTask(taskId); }
      };

      card.addEventListener('touchstart', onStart, { passive: true });
      card.addEventListener('touchmove',  onMove,  { passive: false });
      card.addEventListener('touchend',   onEnd);
      card.addEventListener('mousedown',  onStart);
      card.addEventListener('mousemove',  onMove);
      card.addEventListener('mouseup',    onEnd);
      card.addEventListener('mouseleave', onEnd);
    });
  },

  /* ============================================
     COMPLETE TASK
  ============================================ */
  completeTask(id) {
    try {
      const task = DB.getTasks().find(t => t.id === id);
      if (!task || task.completed) return;

      const wrap = document.getElementById(`wrap-${id}`);
      if (wrap) {
        wrap.classList.add('animating-complete');
        setTimeout(() => {
          DB.updateTask(id, { completed: true, completedAt: new Date().toISOString() });
          const coins = task.isMIT ? 2 : 1;
          UI.addCoins(coins, id);
          UI.showCoinPop(`+${coins}🪙`);
          Utils.haptic(80);
          UI.showToast(task.isMIT ? `MIT complete! +2 coins 🎉` : `Task done! +1 coin 🪙`, '✅');
          refreshAll();
        }, 380);
      } else {
        DB.updateTask(id, { completed: true, completedAt: new Date().toISOString() });
        const coins = task.isMIT ? 2 : 1;
        UI.addCoins(coins, id);
        UI.showToast(`Task done! +${coins} coin 🪙`, '✅');
        refreshAll();
      }
    } catch (e) { console.warn('[TASKS] completeTask:', e); }
  },

  /* ============================================
     DELETE TASK
  ============================================ */
  promptDeleteTask(id) {
    const task = DB.getTasks().find(t => t.id === id);
    if (!task) return;
    this._pendingDelete = { type: 'task', id };
    const txt = document.getElementById('confirm-text');
    if (txt) txt.textContent = `"${task.title}" — delete hoga, undo nahi hoga!`;
    document.getElementById('confirm-modal')?.classList.add('open');
    Utils.haptic(40);
  },

  promptDeleteIdea(id) {
    const ideas = DB.getIdeas();
    const idea  = ideas.find(i => i.id === id);
    if (!idea) return;
    this._pendingDelete = { type: 'idea', id };
    const txt = document.getElementById('confirm-text');
    if (txt) txt.textContent = `Idea delete hoga — undo nahi ho sakta!`;
    document.getElementById('confirm-modal')?.classList.add('open');
    Utils.haptic(40);
  },

  confirmDelete() {
    if (!this._pendingDelete) return;
    const { type, id } = this._pendingDelete;
    const wrap = document.getElementById(`wrap-${id}`);
    if (wrap) {
      wrap.classList.add('animating-delete');
      setTimeout(() => this._doDelete(type, id), 380);
    } else {
      this._doDelete(type, id);
    }
    this.closeConfirm();
  },

  _doDelete(type, id) {
    if (type === 'task') {
      const tasks = DB.getTasks().filter(t => t.id !== id);
      DB.saveTasks(tasks);
      UI.showToast('Task delete ho gaya', '🗑️');
    } else if (type === 'idea') {
      const ideas = DB.getIdeas().filter(i => i.id !== id);
      DB.saveIdeas(ideas);
      UI.showToast('Idea delete ho gaya', '🗑️');
    }
    this._pendingDelete = null;
    refreshAll();
  },

  closeConfirm(event) {
    if (event && event.target !== document.getElementById('confirm-modal')) return;
    document.getElementById('confirm-modal')?.classList.remove('open');
    this._pendingDelete = null;
  },

  /* ============================================
     INBOX ACTIONS
  ============================================ */
  convertIdeaToTask(id) {
    const ideas = DB.getIdeas();
    const idea  = ideas.find(i => i.id === id);
    if (!idea) return;
    // Open add-task sheet pre-filled
    this.showAddTask(idea.title);
    // Remove from inbox
    const updated = ideas.filter(i => i.id !== id);
    DB.saveIdeas(updated);
    Utils.haptic(50);
  },

  convertIdeaToGoal(id) {
    const ideas = DB.getIdeas();
    const idea  = ideas.find(i => i.id === id);
    if (!idea) return;
    DB.addGoal({ title: idea.title, areaId: null, targetDate: null, requiredHours: 0, notes: '' });
    const updated = ideas.filter(i => i.id !== id);
    DB.saveIdeas(updated);
    UI.showToast('Goal mein add ho gaya! 🎯', '✅');
    Utils.haptic(60);
    refreshAll();
  },

  /* ============================================
     ADD TASK SHEET
  ============================================ */
  showAddTask(prefillTitle) {
    this._editId = null;
    this._form = { priority: 'medium', energy: 'medium', isMIT: false, areaId: null };

    // Reset fields
    const titleEl = document.getElementById('at-title');
    if (titleEl) titleEl.value = prefillTitle || '';

    // Render area pills
    this._renderAreaPills();

    // Render goal options
    this._renderGoalSelect();

    // Reset priority chips
    document.querySelectorAll('#at-priority-group .chip-toggle').forEach(c => {
      c.className = 'chip-toggle' + (c.dataset.val === 'medium' ? ' active medium-active' : '');
    });

    // Reset energy chips
    document.querySelectorAll('#at-energy-group .chip-toggle').forEach(c => {
      c.className = 'chip-toggle' + (c.dataset.val === 'medium' ? ' active energy-medium-active' : '');
    });

    // Reset MIT
    const mitRow = document.getElementById('at-mit-toggle');
    if (mitRow) mitRow.classList.remove('mit-on');

    // Reset date
    const dateEl = document.getElementById('at-due-date');
    if (dateEl) dateEl.value = '';

    // Night energy warning
    this._checkEnergyWarning();

    const overlay = document.getElementById('add-task-overlay');
    if (overlay) overlay.classList.add('open');
    setTimeout(() => document.getElementById('at-title')?.focus(), 350);
    Utils.haptic(30);
  },

  closeAddTask() {
    document.getElementById('add-task-overlay')?.classList.remove('open');
  },

  handleSheetOverlayClick(e) {
    if (e.target === document.getElementById('add-task-overlay')) this.closeAddTask();
  },

  _renderAreaPills() {
    const container = document.getElementById('at-area-pills');
    if (!container) return;
    const areas = DB.getAreas();
    if (areas.length === 0) { container.innerHTML = '<span style="font-size:13px;color:var(--muted);">Koi areas nahi</span>'; return; }
    container.innerHTML = [
      `<div class="area-pill-btn ${this._form.areaId === null ? 'active' : ''}" onclick="TASKS.selectArea(null)" style="${this._form.areaId === null ? 'border-color:var(--primary);background:var(--primary-soft);color:var(--primary);' : ''}">Koi nahi</div>`,
      ...areas.map(a => `<div class="area-pill-btn ${this._form.areaId === a.id ? 'active' : ''}" onclick="TASKS.selectArea('${a.id}')" style="${this._form.areaId === a.id ? `border-color:${a.color};background:${a.color}22;color:${a.color};` : ''}">${a.icon} ${UI.escapeHtml(a.name)}</div>`)
    ].join('');
  },

  _renderGoalSelect() {
    const sel = document.getElementById('at-goal-select');
    if (!sel) return;
    const goals = DB.getGoals().filter(g => g.status === 'active');
    sel.innerHTML = `<option value="">— Koi goal nahi —</option>` +
      goals.map(g => `<option value="${g.id}">${UI.escapeHtml(g.title)}</option>`).join('');
  },

  selectArea(id) {
    this._form.areaId = id;
    this._renderAreaPills();
    Utils.haptic(20);
  },

  selectPriority(val) {
    this._form.priority = val;
    const clsMap = { high: 'high-active', medium: 'medium-active', low: 'low-active' };
    document.querySelectorAll('#at-priority-group .chip-toggle').forEach(c => {
      const isActive = c.dataset.val === val;
      c.className = 'chip-toggle' + (isActive ? ` active ${clsMap[val]}` : '');
    });
    Utils.haptic(20);
  },

  selectEnergy(val) {
    this._form.energy = val;
    const clsMap = { low: 'energy-low-active', medium: 'energy-medium-active', deep: 'energy-deep-active' };
    document.querySelectorAll('#at-energy-group .chip-toggle').forEach(c => {
      const isActive = c.dataset.val === val;
      c.className = 'chip-toggle' + (isActive ? ` active ${clsMap[val]}` : '');
    });
    this._checkEnergyWarning();
    Utils.haptic(20);
  },

  _checkEnergyWarning() {
    const warn = document.getElementById('at-energy-warning');
    if (warn) warn.classList.toggle('hidden', !(this._isNightTime() && this._form.energy === 'deep'));
  },

  toggleMIT() {
    this._form.isMIT = !this._form.isMIT;
    const row = document.getElementById('at-mit-toggle');
    if (row) row.classList.toggle('mit-on', this._form.isMIT);
    Utils.haptic(30);
  },

  saveTask() {
    const title = document.getElementById('at-title')?.value?.trim();
    if (!title) {
      UI.showToast('Title dalna zaroori hai! 📝', '⚠️');
      document.getElementById('at-title')?.focus();
      return;
    }

    // Check MIT cap
    if (this._form.isMIT) {
      const existingMITs = DB.getTasks().filter(t => t.isMIT && !t.completed);
      if (existingMITs.length >= 3) {
        UI.showToast('Max 3 MIT allowed! Pehle wale complete karo 🎯', '⚠️');
        return;
      }
    }

    const goalId  = document.getElementById('at-goal-select')?.value || null;
    const dueDate = document.getElementById('at-due-date')?.value || null;

    DB.addTask({
      title,
      areaId:   this._form.areaId,
      goalId:   goalId || null,
      priority: this._form.priority,
      energy:   this._form.energy,
      isMIT:    this._form.isMIT,
      dueDate
    });

    this.closeAddTask();
    Utils.haptic(70);
    UI.showToast(`Task add ho gaya! ${this._form.isMIT ? '⭐ MIT' : ''}`, '✅');
    refreshAll();
    // Auto-switch to tasks tab
    if (UI._activeTab !== 'tasks') UI.switchTab('tasks');
  }
};

/* ============================================
   P4 — FOCUS MODULE
============================================ */
const FOCUS = {
  /* ---- State ---- */
  durationMins: 25,
  isRunning:    false,
  isPaused:     false,
  isBreak:      false,
  elapsedSecs:  0,         // seconds elapsed in current session
  breakSecs:    0,         // seconds elapsed in break
  totalSecs:    25 * 60,   // total seconds for current mode
  _interval:    null,
  selectedAreaId: null,
  selectedTaskId: null,
  soundMode:    'none',    // 'none' | 'bell' | 'rain' | 'ocean'
  pomoRound:    0,         // 0-3
  _audioCtx:    null,
  _ambientNode: null,

  /* ---- Ring constants ---- */
  RING_CIRC:  615.75,   // 2π × 98  (focus screen small ring)
  IMM_CIRC:   722.57,   // 2π × 115 (immersive big ring)

  /* ============================================
     INIT / RENDER SETUP
  ============================================ */
  renderSetup() {
    try {
      this._renderAreaPills();
      this._renderTaskSelect();
      this._renderSessionChips();
      this._renderStatsBar();
      this._syncRoundDots();
      this._updateFlowText();
      // Restore sound toggle icon
      this._updateSoundToggleIcon();
      // If currently running, show immersive
      if (this.isRunning && !this.isPaused) {
        setTimeout(() => this._showImmersive(), 50);
      }
    } catch(e) { console.warn('[FOCUS] renderSetup:', e); }
  },

  _renderAreaPills() {
    const container = document.getElementById('focus-area-pills');
    if (!container) return;
    const areas = DB.getAreas();
    if (areas.length === 0) {
      container.innerHTML = `<span style="font-size:13px;color:var(--muted);">Koi areas nahi – onboarding se add karo</span>`;
      return;
    }
    // Auto-select first area if none selected
    if (!this.selectedAreaId && areas.length > 0) this.selectedAreaId = areas[0].id;

    container.innerHTML = areas.map(a => {
      const active = this.selectedAreaId === a.id;
      return `<div class="focus-area-pill ${active ? 'active' : ''}"
        style="--area-color:${a.color};--area-bg:${a.color}22;"
        onclick="FOCUS.selectArea('${a.id}')">${a.icon} ${UI.escapeHtml(a.name)}</div>`;
    }).join('');
  },

  _renderTaskSelect() {
    const sel = document.getElementById('focus-task-select');
    if (!sel) return;
    const pending = DB.getTasks().filter(t => !t.completed);
    sel.innerHTML = `<option value="">— Koi task link nahi —</option>` +
      pending.map(t => {
        const mark = t.isMIT ? '⭐ ' : '';
        return `<option value="${t.id}">${mark}${UI.escapeHtml(t.title)}</option>`;
      }).join('');
    if (this.selectedTaskId) sel.value = this.selectedTaskId;
    sel.onchange = () => { this.selectedTaskId = sel.value || null; };
  },

  _renderSessionChips() {
    const row = document.getElementById('focus-sessions-row');
    if (!row) return;
    const today = Utils.today();
    const sessions = DB.getSessions().filter(s => s.completedAt && s.completedAt.startsWith(today));
    if (sessions.length === 0) {
      row.innerHTML = `<span style="font-size:13px;color:var(--muted);">Abhi koi session nahi</span>`;
      return;
    }
    const areas = DB.getAreas();
    row.innerHTML = sessions.map(s => {
      const a = areas.find(x => x.id === s.areaId);
      const icon = a ? a.icon : '⏱️';
      return `<div class="focus-session-chip">${icon} ✅ <span style="font-size:10px;color:var(--muted);">${s.duration}m</span></div>`;
    }).join('');
  },

  _renderStatsBar() {
    const today  = Utils.today();
    const allSessions = DB.getSessions();
    const todaySessions = allSessions.filter(s => s.completedAt && s.completedAt.startsWith(today));
    const todayMins = todaySessions.reduce((s, x) => s + (x.duration || 0), 0);
    const weekSessions = Utils.getWeekSessions();
    const user  = DB.getUser();

    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set('fstat-today', todaySessions.length);
    set('fstat-hrs', todayMins >= 60 ? `${(todayMins/60).toFixed(1)}h` : `${todayMins}m`);
    set('fstat-week', weekSessions.length);
    set('fstat-coins', user?.totalCoins || 0);
  },

  /* ============================================
     TIMER CONTROLS
  ============================================ */
  toggleTimer() {
    if (!this.isRunning) {
      this.startTimer();
    } else if (this.isPaused) {
      this.resumeTimer();
    } else {
      this.pauseTimer();
    }
  },

  startTimer() {
    this.isRunning  = true;
    this.isPaused   = false;
    this.isBreak    = false;
    this.elapsedSecs = 0;
    this.totalSecs  = this.durationMins * 60;
    this._syncSelectedTask();
    this._showImmersive();
    this._startInterval();
    this._startAmbient();
    Utils.haptic(60);
    Utils.checkStreakUpdate();
  },

  pauseTimer() {
    this.isPaused = true;
    clearInterval(this._interval);
    this._interval = null;
    this._stopAmbient();
    const btn = document.getElementById('imm-pause-btn');
    if (btn) { btn.textContent = '▶️'; btn.classList.add('paused'); }
    Utils.haptic(30);
  },

  resumeTimer() {
    this.isPaused = false;
    this._startInterval();
    this._startAmbient();
    const btn = document.getElementById('imm-pause-btn');
    if (btn) { btn.textContent = '⏸️'; btn.classList.remove('paused'); }
    Utils.haptic(30);
  },

  stop() {
    if (this.isRunning && !this.isBreak) {
      // Partial session — still save if ≥ 5 min
      if (this.elapsedSecs >= 300) this._saveSession(false);
    }
    this._resetState();
    this._hideImmersive();
    this._stopAmbient();
    document.getElementById('session-complete-overlay')?.classList.remove('active');
    this._syncTimerDisplay();
    this._updateControls();
    refreshFocus();
    refreshAll();
    Utils.haptic(40);
  },

  resetTimer() {
    if (this.isRunning) return;
    this.elapsedSecs = 0;
    this._syncTimerDisplay();
    this._syncRing();
  },

  _startInterval() {
    clearInterval(this._interval);
    this._interval = setInterval(() => this._tick(), 1000);
  },

  _tick() {
    if (this.isBreak) {
      this.breakSecs++;
      const remaining = 300 - this.breakSecs; // 5 min break
      if (remaining <= 0) { this._endBreak(); return; }
      this._updateBreakDisplay(remaining);
    } else {
      this.elapsedSecs++;
      const remaining = this.totalSecs - this.elapsedSecs;
      if (remaining <= 0) { this._onSessionComplete(); return; }
      this._syncTimerDisplay(remaining);
      this._syncRing();
      this._updateFlowText();
    }
  },

  _syncSelectedTask() {
    const sel = document.getElementById('focus-task-select');
    if (sel) this.selectedTaskId = sel.value || null;
  },

  /* ============================================
     SESSION COMPLETE
  ============================================ */
  _onSessionComplete() {
    clearInterval(this._interval);
    this._interval = null;
    this._stopAmbient();
    this._playBell();

    // Confetti
    try {
      if (typeof confetti !== 'undefined') {
        confetti({ particleCount: 100, spread: 70, origin: { y: 0.5 }, colors: ['#6C63FF','#F0C040','#40D080','#FF6B9D'] });
        setTimeout(() => confetti({ particleCount: 60, spread: 50, origin: { y: 0.3 } }), 400);
      }
    } catch {}

    // Save session
    this._saveSession(true);

    // Advance pomo round
    const prevRound = this.pomoRound;
    this.pomoRound = (this.pomoRound + 1) % 4;
    this._syncRoundDots();
    this._syncImmRoundDots();

    // Celebration
    this._showSessionComplete(prevRound);

    // Hide immersive
    this._hideImmersive();

    refreshAll();
    Utils.haptic([100, 50, 100, 50, 100]);
  },

  _saveSession(complete) {
    const user = DB.getUser();
    if (!user) return;
    const mins = Math.round(this.elapsedSecs / 60);
    if (mins < 1) return;

    const coins = complete ? 1 : 0;
    DB.addSession({
      areaId:    this.selectedAreaId,
      taskId:    this.selectedTaskId,
      duration:  mins,
      coinsEarned: coins,
      completed: complete
    });

    if (complete) {
      UI.addCoins(1, null);
    }
  },

  _showSessionComplete(prevRound) {
    const sessionsToday = DB.getSessions().filter(s => s.completedAt && s.completedAt.startsWith(Utils.today()) && s.completed);
    const count = sessionsToday.length;
    const user = DB.getUser();
    const target = user?.todayFocusTarget || (user?.dailyFocusTarget || 2);

    let emoji = '🎉', title = 'Session Complete!', subtitle = 'Bahut accha kiya!';
    if (count === 1)       { emoji = '⚡'; title = 'Shuruaat!'; subtitle = 'Pehla session complete — momentum aa gaya!'; }
    else if (count === 3)  { emoji = '🌊'; title = 'Flow State!'; subtitle = 'Teen sessions — tu zone mein hai!'; }
    else if (count >= target) { emoji = '🏆'; title = 'Target Complete!'; subtitle = `Aaj ka ${target} session target done! Champion! 🔥`; }

    if (prevRound === 3)   { subtitle += '\n\n💡 4 rounds done — 20 min ka long break deserved!'; }

    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set('sc-emoji',    emoji);
    set('sc-title',    title);
    set('sc-subtitle', subtitle);
    set('sc-coins-earned', '+1 coin mila! 🪙');

    document.getElementById('session-complete-overlay')?.classList.add('active');
  },

  startBreak() {
    document.getElementById('session-complete-overlay')?.classList.remove('active');
    this.isBreak = true;
    this.isRunning = true;
    this.isPaused = false;
    this.breakSecs = 0;
    this._showImmersive(true);
    this._startInterval();
    Utils.haptic(50);
  },

  _endBreak() {
    clearInterval(this._interval);
    this._interval = null;
    this.isBreak = false;
    this._hideImmersive();
    this.isRunning = false;
    this._syncTimerDisplay();
    this._updateControls();
    UI.showToast('Break over! Dobara focus karo 🚀', '⚡');
    Utils.haptic(80);
    refreshFocus();
  },

  _updateBreakDisplay(remaining) {
    const m = Math.floor(remaining / 60);
    const s = remaining % 60;
    const str = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    // Update immersive display
    const immEl = document.getElementById('imm-timer-display');
    const immLbl = document.getElementById('imm-mode-label');
    const immFlow = document.getElementById('imm-flow-text');
    if (immEl) immEl.textContent = str;
    if (immLbl) immLbl.textContent = 'BREAK';
    if (immFlow) { immFlow.textContent = 'Break lo – deserve kiya! ☕'; immFlow.className = 'imm-flow-text flow-warm'; }
    // Sync break ring (counts down from 5 min)
    const pct = (300 - this.breakSecs) / 300;
    this._setRingOffset('imm-ring-progress', this.IMM_CIRC, pct, true);
    // Update small ring too
    const focusDigits = document.getElementById('focus-timer-display');
    const focusMode = document.getElementById('focus-mode-label');
    if (focusDigits) { focusDigits.textContent = str; focusDigits.classList.add('break-mode'); }
    if (focusMode) focusMode.textContent = 'BREAK';
  },

  doAgain() {
    document.getElementById('session-complete-overlay')?.classList.remove('active');
    this._resetState();
    this.startTimer();
  },

  goHome() {
    document.getElementById('session-complete-overlay')?.classList.remove('active');
    this._resetState();
    this._syncTimerDisplay();
    this._updateControls();
    UI.switchTab('home');
  },

  /* ============================================
     DISPLAY SYNC
  ============================================ */
  _syncTimerDisplay(remaining) {
    if (remaining === undefined) remaining = this.totalSecs - this.elapsedSecs;
    if (remaining < 0) remaining = 0;
    const m = Math.floor(remaining / 60);
    const s = remaining % 60;
    const str = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;

    const el1 = document.getElementById('focus-timer-display');
    const el2 = document.getElementById('imm-timer-display');
    const lbl1 = document.getElementById('focus-mode-label');
    const lbl2 = document.getElementById('imm-mode-label');
    if (el1) { el1.textContent = str; el1.classList.remove('break-mode'); }
    if (el2) el2.textContent = str;
    if (lbl1) lbl1.textContent = this.durationMins === 25 ? 'POMODORO' : `${this.durationMins} MIN`;
    if (lbl2) lbl2.textContent = this.durationMins === 25 ? 'POMODORO' : `${this.durationMins} MIN`;
  },

  _syncRing() {
    const pct = this.totalSecs > 0
      ? Math.max(0, (this.totalSecs - this.elapsedSecs) / this.totalSecs)
      : 0;
    this._setRingOffset('focus-ring-progress', this.RING_CIRC, pct, false);
    this._setRingOffset('imm-ring-progress',   this.IMM_CIRC,  pct, false);
  },

  _setRingOffset(id, circ, pct, isBreak) {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.strokeDashoffset = circ * (1 - pct);
    if (isBreak) { el.setAttribute('stroke', 'url(#breakGrad)'); el.setAttribute('stroke', 'url(#immBreakGrad)'); }
  },

  _updateFlowText() {
    const elapsed = this.elapsedSecs / 60;
    let text = 'Shuru karo! 🚀';
    let cls  = '';

    if (!this.isRunning) {
      text = 'Shuru karo! 🚀'; cls = '';
    } else if (elapsed < 10) {
      text = 'Warm up... 🔥'; cls = 'flow-warm';
    } else if (elapsed < 20) {
      text = 'Flow aa raha hai! ⚡'; cls = 'flow-coming';
    } else if (elapsed < this.durationMins) {
      text = 'Deep work mode 🧠'; cls = 'flow-deep';
    } else {
      text = 'Flow state hit! 🌊'; cls = 'flow-deep';
    }

    const el1 = document.getElementById('focus-flow-text');
    const el2 = document.getElementById('imm-flow-text');
    if (el1) el1.textContent = text;
    if (el2) { el2.textContent = text; el2.className = `imm-flow-text ${cls}`; }
  },

  _updateControls() {
    const startBtn = document.getElementById('focus-start-btn');
    const stopBtn  = document.getElementById('focus-stop-btn');
    const resetBtn = document.getElementById('focus-reset-btn');
    if (!startBtn) return;

    if (!this.isRunning) {
      startBtn.textContent = '▶️'; startBtn.className = 'focus-btn-main';
      stopBtn?.classList.add('hidden-btn');
      resetBtn?.classList.add('hidden-btn');
    } else if (this.isPaused) {
      startBtn.textContent = '▶️'; startBtn.className = 'focus-btn-main running';
      stopBtn?.classList.remove('hidden-btn');
      resetBtn?.classList.add('hidden-btn');
    } else {
      startBtn.textContent = '⏸️'; startBtn.className = 'focus-btn-main running';
      stopBtn?.classList.remove('hidden-btn');
      resetBtn?.classList.add('hidden-btn');
    }
  },

  _syncRoundDots() {
    ['pomo-rounds', 'imm-pomo-dots'].forEach(containerId => {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.querySelectorAll('.pomo-dot').forEach((dot, i) => {
        dot.className = 'pomo-dot';
        if (i < this.pomoRound) dot.classList.add('done');
        else if (i === this.pomoRound) dot.classList.add('active');
      });
    });
  },

  _syncImmRoundDots() {
    this._syncRoundDots(); // shared logic
  },

  /* ============================================
     IMMERSIVE MODE
  ============================================ */
  _showImmersive(isBreak) {
    // Hide nav
    document.getElementById('bottom-nav')?.style.setProperty('display', 'none', 'important');
    document.getElementById('fab')?.style.setProperty('display', 'none', 'important');

    // Set area label
    const areaLbl = document.getElementById('imm-area-label');
    if (areaLbl) {
      const areas = DB.getAreas();
      const area = areas.find(a => a.id === this.selectedAreaId);
      areaLbl.textContent = area ? `${area.icon} ${area.name}` : '⏱️ Focus';
    }

    // Update pause btn state
    const pauseBtn = document.getElementById('imm-pause-btn');
    if (pauseBtn) {
      pauseBtn.textContent = '⏸️';
      pauseBtn.className = 'imm-pause-btn' + (isBreak ? ' break-mode' : '');
    }

    // Update mode label
    const lbl = document.getElementById('imm-mode-label');
    if (lbl) lbl.textContent = isBreak ? 'BREAK' : (this.durationMins === 25 ? 'POMODORO' : `${this.durationMins} MIN`);

    // Sync ring
    this._syncRing();
    this._syncRoundDots();

    document.getElementById('focus-immersive')?.classList.add('active');
  },

  _hideImmersive() {
    document.getElementById('focus-immersive')?.classList.remove('active');
    document.getElementById('bottom-nav')?.style.removeProperty('display');
    document.getElementById('fab')?.style.removeProperty('display');
  },

  /* ============================================
     SESSION / AREA / DURATION SELECTORS
  ============================================ */
  selectArea(id) {
    this.selectedAreaId = id;
    this._renderAreaPills();
    this._renderTaskSelect();
    Utils.haptic(20);
  },

  selectDuration(mins) {
    if (this.isRunning) return;
    this.durationMins = mins;
    this.totalSecs    = mins * 60;
    this.elapsedSecs  = 0;
    document.querySelectorAll('.focus-dur-card').forEach(c => {
      c.classList.toggle('active', parseInt(c.dataset.mins) === mins);
    });
    this._syncTimerDisplay();
    this._syncRing();
    // Update mode label
    const lbl1 = document.getElementById('focus-mode-label');
    if (lbl1) lbl1.textContent = mins === 25 ? 'POMODORO' : `${mins} MIN`;
    Utils.haptic(20);
  },

  /* ============================================
     SOUND SYSTEM
  ============================================ */
  selectSound(mode) {
    this.soundMode = mode;
    document.querySelectorAll('.sound-chip').forEach(c => {
      c.classList.toggle('active', c.dataset.sound === mode);
    });
    this._updateSoundToggleIcon();
    // If running, switch ambient immediately
    if (this.isRunning && !this.isPaused) {
      this._stopAmbient();
      this._startAmbient();
    }
    Utils.haptic(20);
  },

  cycleSoundMode() {
    const modes = ['none', 'bell', 'rain', 'ocean'];
    const idx   = modes.indexOf(this.soundMode);
    this.selectSound(modes[(idx + 1) % modes.length]);
  },

  _updateSoundToggleIcon() {
    const btn = document.getElementById('focus-sound-toggle');
    const icons = { none: '🔕', bell: '🔔', rain: '🌧️', ocean: '🌊' };
    if (btn) btn.textContent = icons[this.soundMode] || '🔔';
  },

  _getAudioCtx() {
    if (!this._audioCtx) {
      try { this._audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch { return null; }
    }
    return this._audioCtx;
  },

  _playBell() {
    const user = DB.getUser();
    if (user && user.soundEnabled === false) return;
    try {
      const ctx = this._getAudioCtx();
      if (!ctx) return;
      // Two-tone bell
      const times = [0, 0.3];
      times.forEach(t => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(880, ctx.currentTime + t);
        osc.frequency.exponentialRampToValueAtTime(440, ctx.currentTime + t + 0.5);
        gain.gain.setValueAtTime(0.4, ctx.currentTime + t);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + t + 0.9);
        osc.start(ctx.currentTime + t);
        osc.stop(ctx.currentTime + t + 0.9);
      });
    } catch(e) { console.warn('[FOCUS] playBell:', e); }
  },

  _startAmbient() {
    this._stopAmbient();
    if (this.soundMode === 'none') return;
    try {
      const ctx = this._getAudioCtx();
      if (!ctx) return;

      if (this.soundMode === 'rain') {
        // White noise rain
        const bufSize  = ctx.sampleRate * 2;
        const buf      = ctx.createBuffer(1, bufSize, ctx.sampleRate);
        const data     = buf.getChannelData(0);
        for (let i = 0; i < bufSize; i++) data[i] = (Math.random() * 2 - 1) * 0.18;
        const src    = ctx.createBufferSource();
        src.buffer   = buf;
        src.loop     = true;
        const filter = ctx.createBiquadFilter();
        filter.type  = 'bandpass';
        filter.frequency.value = 1200;
        filter.Q.value = 0.3;
        const gain = ctx.createGain();
        gain.gain.value = 0.35;
        src.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
        src.start();
        this._ambientNode = { src, gain, ctx };

      } else if (this.soundMode === 'ocean') {
        // Low-frequency ocean swell
        const bufSize = ctx.sampleRate * 4;
        const buf     = ctx.createBuffer(1, bufSize, ctx.sampleRate);
        const data    = buf.getChannelData(0);
        for (let i = 0; i < bufSize; i++) {
          const swell = Math.sin(i / (ctx.sampleRate * 1.5) * Math.PI);
          data[i] = (Math.random() * 2 - 1) * 0.12 * Math.abs(swell);
        }
        const src = ctx.createBufferSource();
        src.buffer = buf; src.loop = true;
        const filter = ctx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.value = 600;
        const gain = ctx.createGain();
        gain.gain.value = 0.5;
        src.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
        src.start();
        this._ambientNode = { src, gain, ctx };

      } else if (this.soundMode === 'bell') {
        // Gentle periodic tones every 5 min
        this._bellInterval = setInterval(() => {
          if (this.isRunning && !this.isPaused && this.elapsedSecs > 0 && this.elapsedSecs % 300 === 0) {
            this._playBell();
          }
        }, 1000);
        return;
      }
    } catch(e) { console.warn('[FOCUS] startAmbient:', e); }
  },

  _stopAmbient() {
    try {
      if (this._ambientNode) {
        this._ambientNode.gain.gain.linearRampToValueAtTime(0, this._ambientNode.ctx.currentTime + 0.5);
        setTimeout(() => { try { this._ambientNode?.src?.stop(); } catch {} }, 600);
        this._ambientNode = null;
      }
    } catch {}
    if (this._bellInterval) { clearInterval(this._bellInterval); this._bellInterval = null; }
  },

  /* ============================================
     HELPERS
  ============================================ */
  _resetState() {
    clearInterval(this._interval);
    this._interval   = null;
    this.isRunning   = false;
    this.isPaused    = false;
    this.isBreak     = false;
    this.elapsedSecs = 0;
    this.breakSecs   = 0;
    this.totalSecs   = this.durationMins * 60;
    this._updateControls();
    this._updateFlowText();
    this._syncRing();
    this._syncTimerDisplay();
  }
};

/* ============================================
   P5 — GOALS MODULE
============================================ */
const GOALS = {

  /* State */
  activeFilter: 'all',       // 'all' | 'active' | 'completed' | areaId
  activeSubtab: 'goals',     // 'goals' | 'habits'
  _currentGoalId: null,      // goal being viewed in detail
  _editGoalId: null,         // null = new goal
  _agForm: { areaId: null }, // add-goal form state
  _notesTimer: null,

  /* ============================================
     SUBTAB SWITCHING
  ============================================ */
  switchSubtab(tab) {
    this.activeSubtab = tab;
    // Update subtab buttons
    document.getElementById('subtab-goals')?.classList.toggle('active',  tab === 'goals');
    document.getElementById('subtab-habits')?.classList.toggle('active', tab === 'habits');
    // Show/hide panes
    const gp = document.getElementById('goals-pane');
    const hp = document.getElementById('habits-pane');
    if (gp) gp.classList.toggle('hidden-pane', tab !== 'goals');
    if (hp) hp.classList.toggle('active',       tab === 'habits');
    // Update header title + add button label
    const titleEl = document.getElementById('goals-screen-title');
    const lblEl   = document.getElementById('goals-screen-add-label');
    if (titleEl) titleEl.textContent = tab === 'goals' ? 'Goals 🎯' : 'Habits 🔁';
    if (lblEl)   lblEl.textContent   = tab === 'goals' ? 'Goal' : 'Habit';
    // Render the correct pane
    if (tab === 'goals')  { this.renderFilterBar(); this.renderGoalsList(); this.renderSubtitle(); }
    if (tab === 'habits') HABITS.render();
    Utils.haptic(20);
  },

  handleScreenAdd() {
    if (this.activeSubtab === 'habits') HABITS.showAddHabit();
    else this.showAddGoal();
  },

  /* ============================================
     RENDER PIPELINE
  ============================================ */
  render() {
    try {
      if (this.activeSubtab === 'habits') { HABITS.render(); return; }
      this.renderFilterBar();
      this.renderGoalsList();
      this.renderSubtitle();
    } catch(e) { console.warn('[GOALS] render:', e); }
  },

  renderSubtitle() {
    const sub = document.getElementById('goals-subtitle');
    if (!sub) return;
    const goals = DB.getGoals();
    const active = goals.filter(g => g.status === 'active').length;
    const done   = goals.filter(g => g.status === 'completed').length;
    sub.textContent = goals.length === 0
      ? 'Bade sapne, chhoti steps'
      : `${active} active · ${done} completed`;
  },

  /* ============================================
     FILTER BAR
  ============================================ */
  renderFilterBar() {
    const bar = document.getElementById('goals-filter-bar');
    if (!bar) return;
    const areas = DB.getAreas();
    const pills = [
      { id: 'all',       label: 'Sab',       icon: '' },
      { id: 'active',    label: '🔥 Active',  icon: '' },
      { id: 'completed', label: '✅ Done',    icon: '' },
      ...areas.map(a => ({ id: a.id, label: `${a.icon} ${a.name}`, color: a.color }))
    ];
    bar.innerHTML = pills.map(p => {
      const isActive = this.activeFilter === p.id;
      const activeStyle = isActive && p.color
        ? `style="border-color:${p.color};background:${p.color}22;color:${p.color};"`
        : '';
      return `<div class="filter-pill ${isActive ? 'active' : ''}" ${activeStyle} onclick="GOALS.setFilter('${p.id}')">${p.label}</div>`;
    }).join('');
  },

  setFilter(id) {
    this.activeFilter = id;
    Utils.haptic(20);
    this.render();
  },

  /* ============================================
     GOALS LIST
  ============================================ */
  renderGoalsList() {
    const list    = document.getElementById('goals-list');
    const empty   = document.getElementById('goals-empty');
    if (!list) return;

    let goals = DB.getGoals();

    // Apply filter
    if (this.activeFilter === 'active')    goals = goals.filter(g => g.status === 'active');
    else if (this.activeFilter === 'completed') goals = goals.filter(g => g.status === 'completed');
    else if (this.activeFilter !== 'all')  goals = goals.filter(g => g.areaId === this.activeFilter);

    // Sort: active first, then by date
    goals.sort((a, b) => {
      if (a.status !== b.status) return a.status === 'active' ? -1 : 1;
      if (a.targetDate && b.targetDate) return a.targetDate.localeCompare(b.targetDate);
      return 0;
    });

    const allGoals = DB.getGoals();
    if (allGoals.length === 0) {
      empty?.classList.remove('hidden');
      list.innerHTML = '';
      return;
    }
    empty?.classList.add('hidden');

    if (goals.length === 0) {
      list.innerHTML = `<div style="text-align:center;padding:40px 0;font-size:14px;color:var(--muted);">Is filter mein koi goal nahi 🤷</div>`;
      return;
    }

    list.innerHTML = goals.map(g => this._goalCardHTML(g)).join('');
  },

  /* ============================================
     GOAL CARD HTML
  ============================================ */
  _goalCardHTML(goal) {
    const areas  = DB.getAreas();
    const area   = areas.find(a => a.id === goal.areaId);
    const color  = area?.color || '#6C63FF';

    // Progress calc
    const { hrs, pct } = this._calcProgress(goal);
    const reqHrs = goal.requiredHours || 0;
    const pctCapped = Math.min(pct, 100);
    const pctColor = pct >= 100 ? 'var(--success)' : pct >= 60 ? 'var(--warning)' : color;

    // Days left
    const daysTag = this._daysLeftTag(goal.targetDate);

    // Linked tasks
    const tasks = DB.getTasks().filter(t => t.goalId === goal.id);
    const doneTasks = tasks.filter(t => t.completed).length;

    const isComplete = goal.status === 'completed';

    return `
      <div class="goal-card ${isComplete ? 'completed-card' : ''}" onclick="GOALS.openDetail('${goal.id}')">
        <div class="goal-color-strip" style="background:${color};"></div>
        <div class="goal-card-inner">
          ${isComplete ? '<div class="goal-completed-badge">✅</div>' : ''}

          <div class="goal-card-top">
            <div class="goal-area-badge" style="background:${color}22;color:${color};">
              ${area ? area.icon : '🎯'} ${UI.escapeHtml(area?.name || 'No Area')}
            </div>
            ${daysTag}
          </div>

          <div class="goal-card-title">${UI.escapeHtml(goal.title)}</div>

          <div class="goal-progress-row">
            <div class="goal-progress-track">
              <div class="goal-progress-fill" style="width:${pctCapped}%;background:${pctColor};"></div>
            </div>
            <div class="goal-progress-pct" style="color:${pctColor};">${Math.round(pctCapped)}%</div>
          </div>

          <div class="goal-hrs-text">
            ${reqHrs > 0
              ? `${hrs.toFixed(1)} hrs / ${reqHrs} hrs required`
              : `${hrs.toFixed(1)} hrs logged`}
          </div>

          <div class="goal-card-bottom">
            <div class="goal-tasks-count">
              ✅ ${doneTasks}/${tasks.length} tasks
            </div>
            <div class="goal-detail-arrow">Details →</div>
          </div>
        </div>
      </div>`;
  },

  _daysLeftTag(dateStr) {
    if (!dateStr) return '<div class="goal-days-badge">📅 No date</div>';
    const today  = new Date(Utils.today());
    const target = new Date(dateStr);
    const diff   = Math.ceil((target - today) / (1000 * 60 * 60 * 24));
    if (diff < 0) return `<div class="goal-days-badge urgent">⚠️ ${Math.abs(diff)}d overdue</div>`;
    if (diff === 0) return `<div class="goal-days-badge urgent">⚠️ Aaj deadline!</div>`;
    if (diff <= 7)  return `<div class="goal-days-badge soon">⏰ ${diff}d left</div>`;
    return `<div class="goal-days-badge">📅 ${diff}d left</div>`;
  },

  /* ============================================
     PROGRESS CALCULATION
  ============================================ */
  _calcProgress(goal) {
    const tasks   = DB.getTasks().filter(t => t.goalId === goal.id);
    const taskIds = new Set(tasks.map(t => t.id));
    const sessions = DB.getSessions();

    // Sessions linked directly to a task of this goal
    const taskSessions = sessions.filter(s => s.taskId && taskIds.has(s.taskId));
    // Sessions directly on this goal's area (area-level fallback — only if goal has areaId)
    // We intentionally exclude these to avoid double counting; goal-specific tasks are primary
    const totalMins = taskSessions.reduce((s, x) => s + (x.duration || 0), 0);
    const hrs = totalMins / 60;
    const reqHrs = goal.requiredHours || 0;
    const pct = reqHrs > 0 ? (hrs / reqHrs) * 100 : 0;
    return { hrs, pct };
  },

  /* ============================================
     GOAL DETAIL
  ============================================ */
  openDetail(id) {
    this._currentGoalId = id;
    const goals = DB.getGoals();
    const goal  = goals.find(g => g.id === id);
    if (!goal) return;

    this._renderDetailContent(goal);

    const overlay = document.getElementById('goal-detail-overlay');
    // First make it display:flex, then trigger CSS transition
    if (overlay) {
      overlay.style.display = 'flex';
      requestAnimationFrame(() => overlay.classList.add('active'));
    }
    Utils.haptic(30);
  },

  _renderDetailContent(goal) {
    const areas = DB.getAreas();
    const area  = areas.find(a => a.id === goal.areaId);
    const color = area?.color || '#6C63FF';

    // Header
    const titleEl = document.getElementById('gd-title');
    if (titleEl) titleEl.textContent = goal.title;

    // Area row
    const areaRow = document.getElementById('gd-area-row');
    if (areaRow) {
      const isComplete = goal.status === 'completed';
      areaRow.innerHTML = `
        <div class="goal-area-badge" style="background:${color}22;color:${color};">
          ${area ? area.icon : '🎯'} ${UI.escapeHtml(area?.name || 'No Area')}
        </div>
        <div style="font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;
          background:${isComplete ? 'var(--success-soft)' : 'var(--primary-soft)'};
          color:${isComplete ? 'var(--success)' : 'var(--primary)'};">
          ${isComplete ? '✅ Completed' : '🔥 Active'}
        </div>`;
    }

    // Progress ring
    const { hrs, pct } = this._calcProgress(goal);
    const pctCapped = Math.min(pct, 100);
    const CIRC = 364.42;
    const ringEl = document.getElementById('gd-ring-progress');
    const pctTxt = document.getElementById('gd-ring-pct');
    if (ringEl) {
      ringEl.style.strokeDashoffset = CIRC * (1 - pctCapped / 100);
      const pctColor = pct >= 100 ? '#40D080' : pct >= 60 ? '#F0C040' : color;
      ringEl.setAttribute('stroke', pctColor);
    }
    if (pctTxt) {
      pctTxt.textContent = `${Math.round(pctCapped)}%`;
      const pctColor2 = pct >= 100 ? 'var(--success)' : pct >= 60 ? 'var(--warning)' : 'var(--primary)';
      pctTxt.style.color = pctColor2;
    }

    // Info grid
    const tasks = DB.getTasks().filter(t => t.goalId === goal.id);
    const doneTasks = tasks.filter(t => t.completed).length;

    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set('gd-hrs-done', `${hrs.toFixed(1)}h`);
    set('gd-hrs-req',  goal.requiredHours > 0 ? `${goal.requiredHours}h` : '—');

    if (goal.targetDate) {
      const diff = Math.ceil((new Date(goal.targetDate) - new Date(Utils.today())) / 86400000);
      set('gd-days-left', diff < 0 ? `${Math.abs(diff)}d overdue` : `${diff}d`);
    } else {
      set('gd-days-left', '—');
    }
    set('gd-tasks-done', `${doneTasks}/${tasks.length}`);

    // Notes
    const notesEl = document.getElementById('gd-notes');
    if (notesEl) notesEl.value = goal.notes || '';
    const notesSaved = document.getElementById('gd-notes-saved');
    if (notesSaved) notesSaved.textContent = '';

    // Tasks list
    this._renderDetailTasks(tasks);

    // Complete btn
    const completeBtn = document.getElementById('gd-complete-btn');
    if (completeBtn) {
      const isComplete = goal.status === 'completed';
      completeBtn.disabled = isComplete;
      completeBtn.textContent = isComplete ? '✅ Goal Completed!' : '🏆 Goal Complete Karo';
    }
  },

  _renderDetailTasks(tasks) {
    const list = document.getElementById('gd-tasks-list');
    if (!list) return;
    if (tasks.length === 0) {
      list.innerHTML = `<div style="font-size:13px;color:var(--muted);text-align:center;padding:16px;">Koi linked tasks nahi — upar se add karo 👆</div>`;
      return;
    }
    list.innerHTML = tasks.map(t => `
      <div class="gd-task-row">
        <div class="gd-task-cb ${t.completed ? 'done' : ''}">${t.completed ? '✓' : ''}</div>
        <div class="gd-task-title ${t.completed ? 'done' : ''}">${UI.escapeHtml(t.title)}</div>
        ${t.isMIT ? '<span style="font-size:11px;color:var(--warning);font-weight:700;">⭐ MIT</span>' : ''}
      </div>`).join('');
  },

  closeDetail() {
    const overlay = document.getElementById('goal-detail-overlay');
    if (!overlay) return;
    overlay.classList.remove('active');
    setTimeout(() => { overlay.style.display = 'none'; }, 300);
    this._currentGoalId = null;
    if (this._notesTimer) { clearTimeout(this._notesTimer); this._notesTimer = null; }
    Utils.haptic(20);
  },

  handleDetailOverlayClick(e) {
    // Only close if clicking the bg directly — but since detail is full-screen this won't fire
  },

  autoSaveNotes() {
    if (this._notesTimer) clearTimeout(this._notesTimer);
    this._notesTimer = setTimeout(() => {
      if (!this._currentGoalId) return;
      const notes = document.getElementById('gd-notes')?.value || '';
      DB.updateGoal(this._currentGoalId, { notes });
      const savedEl = document.getElementById('gd-notes-saved');
      if (savedEl) { savedEl.textContent = 'Auto-saved ✓'; setTimeout(() => { if (savedEl) savedEl.textContent = ''; }, 2000); }
    }, 800);
  },

  addTaskToGoal() {
    if (!this._currentGoalId) return;
    // Pre-fill add-task sheet with goalId, then close detail
    this.closeDetail();
    setTimeout(() => {
      TASKS.showAddTask();
      // Pre-select goal in task sheet
      setTimeout(() => {
        const goalSel = document.getElementById('at-goal-select');
        if (goalSel) { goalSel.value = this._currentGoalId; }
      }, 400);
    }, 350);
    Utils.haptic(30);
  },

  /* ============================================
     MARK COMPLETE
  ============================================ */
  markComplete() {
    if (!this._currentGoalId) return;
    const goal = DB.getGoals().find(g => g.id === this._currentGoalId);
    if (!goal || goal.status === 'completed') return;

    // Show confirm dialog
    const txt = document.getElementById('confirm-text');
    if (txt) txt.textContent = `"${goal.title}" — Goal complete mark karo! +50 coins milenge! 🏆`;

    // Override confirm button action temporarily
    const confirmBtn = document.getElementById('confirm-delete-btn');
    if (confirmBtn) {
      confirmBtn.textContent = '🏆 Haan, Complete!';
      confirmBtn.style.background = 'var(--success)';
      confirmBtn.style.boxShadow = '0 4px 16px rgba(64,208,128,0.3)';
      this._awaitingGoalComplete = true;
    }
    document.getElementById('confirm-modal')?.classList.add('open');
    Utils.haptic(40);
  },

  _awaitingGoalComplete: false,

  /* Called from TASKS.confirmDelete — check if goal complete is pending */
  handleConfirmClick() {
    if (this._awaitingGoalComplete) {
      this._awaitingGoalComplete = false;
      this._doGoalComplete();
      return true; // handled
    }
    return false;
  },

  _doGoalComplete() {
    if (!this._currentGoalId) return;
    const goal = DB.getGoals().find(g => g.id === this._currentGoalId);
    if (!goal) return;

    DB.updateGoal(this._currentGoalId, { status: 'completed', completedAt: new Date().toISOString() });
    UI.addCoins(50, null);
    UI.showCoinPop('+50🪙');
    Utils.haptic([100, 50, 100, 50, 100]);

    // Confetti burst
    try {
      if (typeof confetti !== 'undefined') {
        confetti({ particleCount: 150, spread: 100, origin: { y: 0.4 }, colors: ['#6C63FF','#F0C040','#40D080','#FF6B9D','#F05060'] });
        setTimeout(() => confetti({ particleCount: 80, spread: 60, origin: { y: 0.2 }, colors: ['#F0C040','#40D080'] }), 500);
      }
    } catch {}

    // Badge unlock
    this._unlockBadge('🎯', 'Goal Crusher!', 'Ek goal complete kiya — baaki bhi karo!');

    UI.showToast(`Goal complete! +50 coins 🎉`, '🏆');
    document.getElementById('confirm-modal')?.classList.remove('open');

    // Reset confirm button
    const confirmBtn = document.getElementById('confirm-delete-btn');
    if (confirmBtn) {
      confirmBtn.textContent = 'Haan, Delete Karo';
      confirmBtn.style.background = '';
      confirmBtn.style.boxShadow = '';
    }

    // Update detail view
    const goal2 = DB.getGoals().find(g => g.id === this._currentGoalId);
    if (goal2) this._renderDetailContent(goal2);

    refreshAll();
  },

  _unlockBadge(emoji, title, sub) {
    const toast = document.getElementById('badge-toast');
    const emojiEl = document.getElementById('badge-emoji');
    const titleEl = document.getElementById('badge-title');
    const subEl   = document.getElementById('badge-sub');
    if (!toast) return;
    if (emojiEl) emojiEl.textContent = emoji;
    if (titleEl) titleEl.textContent = title;
    if (subEl)   subEl.textContent   = sub;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3500);
  },

  /* ============================================
     ADD GOAL SHEET
  ============================================ */
  showAddGoal() {
    this._editGoalId = null;
    this._agForm = { areaId: null };

    const titleEl = document.getElementById('ag-title');
    if (titleEl) titleEl.value = '';
    const hoursEl = document.getElementById('ag-hours');
    if (hoursEl) hoursEl.value = '';
    const dateEl = document.getElementById('ag-date');
