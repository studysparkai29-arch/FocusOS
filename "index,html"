/* ============================================
   DB MODULE
============================================ */
const DB = {
  getData(key) {
    try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : null; }
    catch (e) { console.warn('[DB] getData error:', key, e); return null; }
  },
  saveData(key, val) {
    try { localStorage.setItem(key, JSON.stringify(val)); return true; }
    catch (e) { console.warn('[DB] saveData error:', key, e); return false; }
  },
  generateId() { return `${Date.now()}_${Math.random().toString(36).substr(2, 9)}`; },
  getUser()   { return this.getData(KEYS.USER); },
  saveUser(u) { return this.saveData(KEYS.USER, u); },
  initStorage() {
    const defaults = { [KEYS.AREAS]:[], [KEYS.GOALS]:[], [KEYS.TASKS]:[], [KEYS.SESSIONS]:[], [KEYS.HABITS]:[], [KEYS.IDEAS]:[] };
    for (const [k, v] of Object.entries(defaults)) { if (this.getData(k) === null) this.saveData(k, v); }
  },
  getAreas()       { return this.getData(KEYS.AREAS)    || []; },
  saveAreas(a)     { return this.saveData(KEYS.AREAS, a); },
  getGoals()       { return this.getData(KEYS.GOALS)    || []; },
  saveGoals(g)     { return this.saveData(KEYS.GOALS, g); },
  addGoal(goal) {
    const goals = this.getGoals();
    goals.push({ ...goal, id: this.generateId(), status: 'active', createdAt: new Date().toISOString() });
    this.saveGoals(goals); return goals;
  },
  getTasks()       { return this.getData(KEYS.TASKS)    || []; },
  saveTasks(t)     { return this.saveData(KEYS.TASKS, t); },
  addTask(task) {
    const tasks = this.getTasks();
    const t = { id: this.generateId(), areaId: null, goalId: null, priority: 'medium', energy: 'medium', isMIT: false, dueDate: null, completed: false, createdAt: new Date().toISOString(), ...task };
    tasks.push(t); this.saveTasks(tasks); return t;
  },
  updateTask(id, changes) {
    const tasks = this.getTasks();
    const idx = tasks.findIndex(t => t.id === id);
    if (idx === -1) return null;
    tasks[idx] = { ...tasks[idx], ...changes };
    this.saveTasks(tasks); return tasks[idx];
  },
  getMITTasks() { return this.getTasks().filter(t => t.isMIT && !t.completed); },
  getMITTask()  { return this.getMITTasks()[0] || null; },
  getSessions()    { return this.getData(KEYS.SESSIONS) || []; },
  saveSessions(s)  { return this.saveData(KEYS.SESSIONS, s); },
  addSession(s) {
    const sessions = this.getSessions();
    sessions.push({ ...s, id: this.generateId(), completedAt: new Date().toISOString() });
    this.saveSessions(sessions); return sessions;
  },
  getHabits()      { return this.getData(KEYS.HABITS)   || []; },
  saveHabits(h)    { return this.saveData(KEYS.HABITS, h); },
  addHabit(habit) {
    const habits = this.getHabits();
    habits.push({ ...habit, id: this.generateId(), streak: 0, completedDates: [], createdAt: new Date().toISOString() });
    this.saveHabits(habits); return habits;
  },
  getIdeas()       { return this.getData(KEYS.IDEAS)    || []; },
  saveIdeas(i)     { return this.saveData(KEYS.IDEAS, i); },
  addIdea(idea) {
    const ideas = this.getIdeas();
    ideas.push({ ...idea, id: this.generateId(), convertedTo: null, createdAt: new Date().toISOString() });
    this.saveIdeas(ideas); return ideas;
  }
};

/* ============================================
   UTILS MODULE
============================================ */
const Utils = {
  formatDate(iso)  { try { return new Date(iso).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }); } catch { return iso; } },
  formatTime(mins) { const m = Math.floor(mins), s = Math.round((mins - m) * 60); return `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`; },
  today()     { return new Date().toISOString().split('T')[0]; },
  yesterday() { const d = new Date(); d.setDate(d.getDate() - 1); return d.toISOString().split('T')[0]; },

  greetingText() {
    const h = new Date().getHours();
    if (h >= 6  && h < 12) return 'Good Morning! 🌅';
    if (h >= 12 && h < 17) return 'Good Afternoon! ☀️';
    if (h >= 17 && h < 21) return 'Good Evening! 🌆';
    return 'Good Night! 🌙';
  },

  shortDate() {
    return new Date().toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short' });
  },

  getDailyQuote() {
    const dayIdx = new Date().getDay(); // 0-6
    return QUOTES[dayIdx % QUOTES.length];
  },

  calculateLevel(coins) {
    if (coins <= 20)  return { level: 1, name: 'Beginner 🌱' };
    if (coins <= 50)  return { level: 2, name: 'Focused ⚡' };
    if (coins <= 100) return { level: 3, name: 'Achiever 🎯' };
    if (coins <= 200) return { level: 4, name: 'Champion 🏆' };
    return { level: 5, name: 'Life Master 👑' };
  },

  getTodayFocusHours() { return this.getTodayFocusMins() / 60; },

  getTodayFocusMins() {
    const today = this.today();
    return DB.getSessions().filter(s => s.completedAt && s.completedAt.startsWith(today)).reduce((sum, s) => sum + (s.duration || 0), 0);
  },

  getWeekSessions() {
    const msInWeek = 7 * 24 * 60 * 60 * 1000;
    const weekAgo = new Date(Date.now() - msInWeek).toISOString();
    return DB.getSessions().filter(s => s.completedAt > weekAgo);
  },

  getMomentumScore() {
    try {
      const user = DB.getUser();
      if (!user) return 0;
      const streakScore  = Math.min((user.streak || 0) * 2, 20);
      const mits = DB.getMITTasks();
      const allMITs = DB.getTasks().filter(t => t.isMIT);
      const doneToday = allMITs.filter(t => t.completed && t.completedAt && t.completedAt.startsWith(this.today()));
      const mitScore = allMITs.length > 0 ? (doneToday.length / allMITs.length) * 25 : 12;
      const target = (user.dailyFocusTarget || 2) * 60;
      const focusScore = Math.min((this.getTodayFocusMins() / target) * 20, 20);
      const habits = DB.getHabits();
      const done = habits.filter(h => h.completedDates && h.completedDates.includes(this.today()));
      const habitScore = habits.length > 0 ? (done.length / habits.length) * 15 : 7;
      return Math.min(Math.round(streakScore + mitScore + focusScore + habitScore), 100);
    } catch { return 0; }
  },

  checkStreakUpdate() {
    try {
      const user = DB.getUser();
      if (!user) return;
      const today = this.today(), yesterday = this.yesterday();
      const last = user.lastActiveDate ? user.lastActiveDate.split('T')[0] : null;
      if (last === today) return;
      if (last === yesterday) { user.streak = (user.streak || 0) + 1; }
      else { user.streak = 0; } // recovery — no harsh msg
      user.lastActiveDate = new Date().toISOString();
      DB.saveUser(user);
    } catch (e) { console.warn('[Utils] checkStreakUpdate:', e); }
  },

  isRecoveryMode() {
    try {
      const user = DB.getUser();
      if (!user || !user.lastActiveDate) return false;
      const last = new Date(user.lastActiveDate);
      const diff = (Date.now() - last.getTime()) / (1000 * 60 * 60 * 24);
      return user.streak === 0 && diff > 2;
    } catch { return false; }
  },

  getSmartSuggestion() {
    try {
      const user = DB.getUser();
      const name = user?.name || 'Dost';
      if (!user) return 'Aaj ka pehla focus session shuru karo! 🚀';

      // Streak break recovery
      if (user.streak === 0 && this.isRecoveryMode()) {
        return `Koi baat nahi ${name}! Aaj se fresh start 🔥`;
      }

      // Morning + no MIT set
      const hour = new Date().getHours();
      const mits = DB.getMITTasks();
      if (hour >= 5 && hour < 12 && mits.length === 0) {
        return `${name}, aaj ke MIT set karo! 🎯`;
      }

      // MIT pending
      if (mits.length > 0) return `MIT pending: "${mits[0].title}" — pehle yahi karo! 🎯`;

      // Best week check
      const weekSessions = this.getWeekSessions();
      const prevWeekAgo = new Date(Date.now() - 14*24*60*60*1000).toISOString();
      const weekAgo     = new Date(Date.now() - 7*24*60*60*1000).toISOString();
      const prevWeekSessions = DB.getSessions().filter(s => s.completedAt > prevWeekAgo && s.completedAt < weekAgo);
      if (weekSessions.length >= 7 && weekSessions.length > prevWeekSessions.length) {
        return `${name} yeh tumhari best week thi! 🏆`;
      }

      // Goal near deadline (≤30 days)
      const activeGoals = DB.getGoals().filter(g => g.status === 'active' && g.targetDate);
      for (const g of activeGoals) {
        const days = Math.ceil((new Date(g.targetDate) - new Date(this.today())) / 86400000);
        if (days > 0 && days <= 30) {
          return `${name}, "${g.title}" mein ${days} din bache hain!`;
        }
      }

      // Area neglect (3+ days no session in any area)
      const areas = DB.getAreas();
      const allSessions = DB.getSessions();
      for (const a of areas) {
        const areaSess = allSessions.filter(s => s.areaId === a.id);
        if (areaSess.length > 0) {
          const last = areaSess.sort((x,y) => y.completedAt.localeCompare(x.completedAt))[0];
          const daysSince = Math.floor((Date.now() - new Date(last.completedAt).getTime()) / 86400000);
          if (daysSince >= 3) {
            return `${name}, ${a.name} ${daysSince} din se chhoot raha hai! ${a.icon}`;
          }
        }
      }

      // Focus target
      const todaySess = DB.getSessions().filter(s => s.completedAt && s.completedAt.startsWith(this.today()));
      if (todaySess.length === 0) return `${name}, aaj abhi tak koi focus session nahi — streak bachao! 🔥`;
      const target = user.dailyFocusTarget || 2;
      const actual = this.getTodayFocusHours();
      if (actual < target) return `Target se ${(target - actual).toFixed(1)} hours peeche ho — chalo ${name}! ⚡`;
      return `Aaj ka target almost done ${name}! Keep going! 🏆`;
    } catch { return 'Focus session shuru karo! 🚀'; }
  },

  getCurrentWeekChallenge() {
    const weekNum = Math.floor(Date.now() / (7 * 24 * 60 * 60 * 1000));
    const areas = DB.getAreas();
    if (areas.length > 0) {
      const weekAgo = new Date(Date.now() - 7*24*60*60*1000).toISOString();
      const weekSessions = DB.getSessions().filter(s => s.completedAt > weekAgo);
      const areaData = areas.map(a => ({
        area: a,
        count: weekSessions.filter(s => s.areaId === a.id).length
      }));
      const weakest = areaData.reduce((a, b) => a.count <= b.count ? a : b);
      const templates = [
        { id: `area_${weakest.area.id}_w${weekNum}`, title: `${weakest.area.icon} ${weakest.area.name}: 5 Sessions`, desc: `${weakest.area.name} mein 5 focus sessions karo is hafte`, type: 'area_sessions', areaId: weakest.area.id, target: 5, reward: 20 },
        { id: `streak5_w${weekNum}`,    title: '5 Din Streak 🔥',    desc: '5 consecutive days focus karo',     type: 'streak',    target: 5,  reward: 25 },
        { id: `sessions10_w${weekNum}`, title: '10 Sessions 🍅',     desc: 'Is hafte 10 focus sessions karo',    type: 'sessions',  target: 10, reward: 30 },
        { id: `mit7_w${weekNum}`,       title: 'MIT Master 🎯',      desc: 'Is hafte 7 MIT tasks complete karo', type: 'mit_done',  target: 7,  reward: 35 },
      ];
      return templates[weekNum % templates.length];
    }
    return WEEKLY_CHALLENGES[weekNum % WEEKLY_CHALLENGES.length];
  },

  getChallengeProgress(challenge) {
    try {
      const weekSessions = this.getWeekSessions();
      if (challenge.type === 'area_sessions') {
        return weekSessions.filter(s => s.areaId === challenge.areaId).length;
      }
      if (challenge.type === 'streak')   return DB.getUser()?.streak || 0;
      if (challenge.type === 'sessions') return weekSessions.length;
      if (challenge.type === 'mit_done') {
        const weekAgo = new Date(Date.now() - 7*24*60*60*1000).toISOString();
        return DB.getTasks().filter(t => t.isMIT && t.completed && t.completedAt > weekAgo).length;
      }
      if (challenge.type === 'areas') {
        const areaIds = new Set(weekSessions.map(s => s.areaId).filter(Boolean));
        return areaIds.size;
      }
      if (challenge.type === 'coins') {
        return weekSessions.reduce((sum, s) => sum + (s.coinsEarned || 0), 0);
      }
      return 0;
    } catch { return 0; }
  },

  haptic(d) { try { if (navigator.vibrate) navigator.vibrate(d || 50); } catch {} },

  getWeekString() {
    const d = new Date();
    const day = d.getDay() || 7;
    const thursday = new Date(d);
    thursday.setDate(d.getDate() + 4 - day);
    const yearStart = new Date(thursday.getFullYear(), 0, 1);
    const weekNum = Math.ceil((((thursday - yearStart) / 86400000) + 1) / 7);
    return `${thursday.getFullYear()}-W${String(weekNum).padStart(2,'0')}`;
  }
};

