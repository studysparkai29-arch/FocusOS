  _getHeatmapColor(hrs) {
    if (hrs === 0)   return '#2A2A3A';
    if (hrs <= 2)    return '#4040A0';
    if (hrs <= 4)    return '#6C63FF';
    return '#40D080';
  },

  _renderHeatmapRows() {
    const el = document.getElementById('st-heatmap-rows');
    if (!el) return;

    const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const sessions = DB.getSessions();
    const today = new Date();

    // Build last 7 days
    const days = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const dateStr = d.toISOString().split('T')[0];
      const daySessions = sessions.filter(s => s.completedAt && s.completedAt.startsWith(dateStr));
      const mins = daySessions.reduce((sum, s) => sum + (s.duration || 0), 0);
      days.push({ dateStr, dayName: dayNames[d.getDay()], hrs: mins / 60, sessionCount: daySessions.length });
    }

    const maxHrs = Math.max(...days.map(d => d.hrs), 1);
    const bestDay = days.reduce((a, b) => a.hrs >= b.hrs ? a : b);

    el.innerHTML = days.map(d => {
      const pct   = (d.hrs / maxHrs) * 100;
      const color = this._getHeatmapColor(d.hrs);
      const isBest = d.dateStr === bestDay.dateStr && d.hrs > 0;
      const hrsLabel = d.hrs === 0 ? '0h' : `${d.hrs.toFixed(1)}h`;
      return `
        <div class="st-heatmap-row ${isBest ? 'best' : ''}">
          <div class="st-hm-day">${d.dayName}</div>
          <div class="st-hm-track">
            <div class="st-hm-fill" style="width:${Math.max(pct, d.hrs > 0 ? 4 : 0)}%;background:${color};"></div>
          </div>
          <div class="st-hm-label" style="color:${color !== '#2A2A3A' ? color : 'var(--muted)'};">${hrsLabel}</div>
        </div>`;
    }).join('');
  },

  _renderHeatmapInsight() {
    const el = document.getElementById('st-hm-insight');
    if (!el) return;

    const sessions = DB.getSessions();
    const today = new Date();
    const days = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const dateStr = d.toISOString().split('T')[0];
      const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      const mins = sessions.filter(s => s.completedAt?.startsWith(dateStr)).reduce((sum, s) => sum + (s.duration || 0), 0);
      days.push({ name: dayNames[d.getDay()], hrs: mins / 60 });
    }

    const sorted = [...days].sort((a, b) => b.hrs - a.hrs);
    const best   = sorted[0];
    const worst  = sorted[sorted.length - 1];
    const avgHrs = days.reduce((s, d) => s + d.hrs, 0) / 7;
    const totalSessions = sessions.filter(s => {
      const d = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
      return s.completedAt > d;
    }).length;

    el.innerHTML = `
      <div class="st-hm-insight-row">🌟 <span><strong>Best day:</strong> ${best.hrs > 0 ? `${best.name} — ${best.hrs.toFixed(1)}h` : 'Abhi koi data nahi'}</span></div>
      <div class="st-hm-insight-row">📈 <span><strong>Avg daily:</strong> ${avgHrs.toFixed(1)} hrs</span></div>
      <div class="st-hm-insight-row">🍅 <span><strong>This week:</strong> ${totalSessions} sessions</span></div>
      ${worst.hrs < best.hrs * 0.3 && best.hrs > 0 ? `<div class="st-hm-insight-row">💡 <span><strong>Improve:</strong> ${worst.name} — ${worst.hrs.toFixed(1)}h</span></div>` : ''}
    `;
  },

  /* Bar chart — sessions per day */
  _renderBarChart() {
    destroyChart('st-bar');
    const canvas = document.getElementById('st-bar-chart');
    if (!canvas) return;

    const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const sessions = DB.getSessions();
    const today = new Date();
    const labels = [], data = [];

    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const dateStr = d.toISOString().split('T')[0];
      labels.push(dayNames[d.getDay()]);
      data.push(sessions.filter(s => s.completedAt?.startsWith(dateStr)).length);
    }

    try {
      const chart = new Chart(canvas, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            data,
            backgroundColor: data.map(v => v > 0 ? 'rgba(108,99,255,0.7)' : 'rgba(42,42,58,0.5)'),
            borderColor:     data.map(v => v > 0 ? '#6C63FF' : '#2A2A3A'),
            borderWidth: 1.5,
            borderRadius: 6,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.raw} sessions` } } },
          scales: {
            x: { grid: { color: '#2A2A3A' }, ticks: { color: '#7070A0', font: { size: 11 } } },
            y: { min: 0, grid: { color: '#2A2A3A' }, ticks: { color: '#7070A0', font: { size: 10 }, stepSize: 1 } }
          },
          animation: { duration: 700 }
        }
      });
      saveChart('st-bar', chart);
    } catch(e) { console.warn('[STATS] bar chart:', e); }
  },

  /* ============================================
     TAB 3 — ACHIEVEMENTS
  ============================================ */
  _renderAchievements() {
    this._renderLevelCard();
    this._renderBadgesGrid();
    this._renderAllTimeStats();
  },

  _renderLevelCard() {
    const user = DB.getUser();
    if (!user) return;
    const coins  = user.totalCoins || 0;
    const level  = Utils.calculateLevel(coins);
    const thresh = this.LEVEL_THRESHOLDS;

    // Find progress to next level
    const lvlIdx = level.level - 1; // 0-based
    const curMin = thresh[lvlIdx];
    const curMax = thresh[lvlIdx + 1] === Infinity ? coins + 100 : thresh[lvlIdx + 1];
    const pct    = Math.min(((coins - curMin) / (curMax - curMin)) * 100, 100);
    const toNext = thresh[lvlIdx + 1] === Infinity ? 0 : thresh[lvlIdx + 1] - coins;

    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set('st-ach-level', level.name);
    set('st-ach-level-sub', level.level === 5 ? 'Highest level achieved! 👑' : `Level ${level.level} / 5`);
    set('st-ach-coins', coins);
    set('st-ach-next', level.level < 5 ? `${toNext} coins to next level` : '🏆 Max level!');

    const fillEl = document.getElementById('st-level-fill');
    if (fillEl) fillEl.style.width = `${pct}%`;
  },

  _renderBadgesGrid() {
    const el = document.getElementById('st-badges-grid');
    if (!el) return;
    const user = DB.getUser();
    if (!user) return;

    el.innerHTML = this.BADGES.map(b => {
      const earned = b.check(user);
      return `
        <div class="st-badge-card ${earned ? 'earned' : 'locked'}">
          <div class="st-badge-emoji">${b.emoji}</div>
          <div class="st-badge-name">${b.name}</div>
          <div class="st-badge-req">${earned ? '✓ Earned!' : b.req}</div>
        </div>`;
    }).join('');
  },

  _renderAllTimeStats() {
    const el = document.getElementById('st-alltime-grid');
    if (!el) return;

    const sessions = DB.getSessions();
    const totalMins = sessions.reduce((sum, s) => sum + (s.duration || 0), 0);
    const totalHrs  = (totalMins / 60).toFixed(1);
    const user = DB.getUser();
    const completedGoals = DB.getGoals().filter(g => g.status === 'completed').length;
    const bestStreak = user?.streak || 0; // simplified: current streak as best

    const cards = [
      { val: `${totalHrs}h`,          label: 'Total focus hours' },
      { val: sessions.length,          label: 'Total sessions'    },
      { val: `${bestStreak}🔥`,        label: 'Current streak'    },
      { val: completedGoals,           label: 'Goals completed'   },
    ];

    el.innerHTML = cards.map(c => `
      <div class="st-alltime-card">
        <div class="st-alltime-val">${c.val}</div>
        <div class="st-alltime-label">${c.label}</div>
      </div>`).join('');
