      document.getElementById('ag-title')?.focus();
      return;
    }
    const hours = parseInt(document.getElementById('ag-hours')?.value) || 0;
    const date  = document.getElementById('ag-date')?.value || null;
    const notes = document.getElementById('ag-notes')?.value?.trim() || '';

