/* ============================================
   DAILY PLANNING STATE (P2 NEW)
============================================ */
const DP = {
  currentStep: 0,
  totalSteps: 4,
  selectedMITs: new Set(),
  focusSessions: 2,
  mainAreaId: null,
  _pendingTaskIds: new Set(), // tasks user marked done in step 0

  init() {
    this.selectedMITs.clear();
    this._pendingTaskIds.clear();
    this.focusSessions = 2;
    this.mainAreaId = null;
    this.currentStep = 0;
    this.updateProgress();
    this.renderPendingTasks();
    this.renderMITSelector();
    this.renderAreaGrid();
    this.updateHeader();
    this.updateNavButtons();
  },

  updateHeader() {
    const el = document.getElementById('dp-header-title');
    const user = DB.getUser();
    if (el && user) el.textContent = `${Utils.greetingText().replace(/!.*/, '')}, ${user.name}! 🌅`;
  },

  updateProgress() {
    for (let i = 0; i < this.totalSteps; i++) {
      const dot = document.getElementById(`dpdot-${i}`);
      if (!dot) continue;
      dot.className = 'dp-progress-dot';
      if (i < this.currentStep) dot.classList.add('done');
      if (i === this.currentStep) dot.classList.add('active');
    }
  },

  showStep(n) {
    for (let i = 0; i < this.totalSteps; i++) {
      const el = document.getElementById(`dp-step-${i}`);
      if (el) el.classList.toggle('active', i === n);
    }
    this.currentStep = n; this.updateProgress(); this.updateNavButtons();
  },

  updateNavButtons() {
    const back = document.getElementById('dp-back-btn'), next = document.getElementById('dp-next-btn');
    if (!back || !next) return;
    back.style.display = this.currentStep > 0 ? '' : 'none';
    if (this.currentStep === this.totalSteps - 1) {
      next.textContent = 'Din Shuru Karein! 🚀';
      next.className = 'btn btn-warning';
    } else {
      next.textContent = 'Aage →';
      next.className = 'btn btn-primary';
    }
  },

  next() {
    if (this.currentStep === this.totalSteps - 1) { this.finish(); return; }
    this.showStep(this.currentStep + 1);
    Utils.haptic(30);
  },

  back() {
    if (this.currentStep > 0) { this.showStep(this.currentStep - 1); Utils.haptic(20); }
  },

  renderPendingTasks() {
    const list = document.getElementById('dp-pending-list');
    const empty = document.getElementById('dp-pending-empty');
    if (!list) return;
    const tasks = DB.getTasks().filter(t => !t.completed);
    if (tasks.length === 0) {
      list.innerHTML = ''; if (empty) empty.style.display = '';
      return;
    }
    if (empty) empty.style.display = 'none';
    list.innerHTML = tasks.map(t => `
      <div class="dp-task-row" id="dptr-${t.id}" onclick="DP.togglePendingTask('${t.id}')">
        <div class="dp-task-check" id="dptc-${t.id}">✓</div>
        <span class="dp-task-label">${UI.escapeHtml(t.title)}</span>
        ${t.isMIT ? '<span style="font-size:10px;color:var(--primary);font-weight:700;background:var(--primary-soft);padding:2px 8px;border-radius:20px;">MIT</span>' : ''}
      </div>`).join('');
  },

  togglePendingTask(id) {
    const row = document.getElementById(`dptr-${id}`);
    if (!row) return;
    row.classList.toggle('done-today');
    if (row.classList.contains('done-today')) { this._pendingTaskIds.add(id); }
    else { this._pendingTaskIds.delete(id); }
    Utils.haptic(25);
  },

  renderMITSelector() {
    const list = document.getElementById('dp-mit-list');
    const empty = document.getElementById('dp-mit-empty');
    if (!list) return;
    const tasks = DB.getTasks().filter(t => !t.completed);
    if (tasks.length === 0) { list.innerHTML = ''; if (empty) empty.style.display = ''; return; }
    if (empty) empty.style.display = 'none';
    list.innerHTML = tasks.map((t, i) => `
      <div class="mit-select-item" id="msi-${t.id}" onclick="DP.toggleMIT('${t.id}')">
        <div class="mit-select-num" id="msn-${t.id}">${i + 1}</div>
        <span class="mit-select-label">${UI.escapeHtml(t.title)}</span>
        ${t.isMIT ? '<span style="font-size:10px;color:var(--primary);font-weight:700;background:var(--primary-soft);padding:2px 8px;border-radius:20px;">MIT</span>' : ''}
      </div>`).join('');
    // Pre-select existing MITs
    tasks.filter(t => t.isMIT).forEach(t => { this.selectedMITs.add(t.id); document.getElementById(`msi-${t.id}`)?.classList.add('selected'); });
    this.updateMITHint();
  },

  toggleMIT(id) {
    if (this.selectedMITs.has(id)) {
      this.selectedMITs.delete(id);
      document.getElementById(`msi-${id}`)?.classList.remove('selected');
    } else {
      if (this.selectedMITs.size >= 3) { UI.showToast('Maximum 3 MIT select kar sakte ho!', '⚠️'); return; }
      this.selectedMITs.add(id);
      document.getElementById(`msi-${id}`)?.classList.add('selected');
    }
    this.updateMITHint(); Utils.haptic(25);
  },

  updateMITHint() {
    const hint = document.getElementById('dp-mit-hint');
    if (hint) hint.textContent = `${this.selectedMITs.size} / 3 selected`;
  },

  selectSessions(n) {
    this.focusSessions = n;
    document.querySelectorAll('.session-card').forEach(c => {
      c.classList.toggle('selected', parseInt(c.dataset.n) === n);
    });
    Utils.haptic(25);
  },

  renderAreaGrid() {
    const grid = document.getElementById('dp-area-grid');
    if (!grid) return;
    const areas = DB.getAreas();
    if (areas.length === 0) {
      grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:var(--muted);font-size:14px;padding:20px;">Koi areas saved nahi — onboarding se add karo</div>';
      return;
    }
    grid.innerHTML = areas.map(a => `
      <div class="area-focus-card" id="afc-${a.id}" onclick="DP.selectArea('${a.id}')" style="border-color:${a.id === this.mainAreaId ? a.color : 'var(--border)'}">
        <span class="area-focus-icon">${a.icon}</span>
        <span class="area-focus-name">${UI.escapeHtml(a.name)}</span>
      </div>`).join('');
  },

  selectArea(id) {
    this.mainAreaId = id;
    const areas = DB.getAreas();
    areas.forEach(a => {
      const card = document.getElementById(`afc-${a.id}`);
      if (card) {
        card.classList.toggle('selected', a.id === id);
        card.style.borderColor = a.id === id ? a.color : 'var(--border)';
      }
    });
    Utils.haptic(30);
  },

  finish() {
    try {
      // Mark selected pending tasks as done
      this._pendingTaskIds.forEach(id => {
        DB.updateTask(id, { completed: true, completedAt: new Date().toISOString() });
      });

      // Update MIT flags
      const allTasks = DB.getTasks();
      allTasks.forEach(t => {
        const shouldBeMIT = this.selectedMITs.has(t.id);
        if (t.isMIT !== shouldBeMIT) DB.updateTask(t.id, { isMIT: shouldBeMIT });
      });

      // Save daily planning data to user
      const user = DB.getUser();
      if (user) {
        user.lastPlanningDate = Utils.today();
        user.todayFocusTarget = this.focusSessions;
        user.todayMainArea = this.mainAreaId;
        DB.saveUser(user);
      }

      // Close overlay
      document.getElementById('daily-planning-overlay')?.classList.remove('active');
      Utils.haptic(80);
      UI.showToast('Din ka plan ready hai! Let\'s go! 🚀', '🌅');
      refreshAll();
    } catch (e) { console.error('[DP] finish error:', e); }
  }
};

/* ============================================
   UI MODULE — P1 + P2 COMBINED
============================================ */
const UI = {
